---
// CallOverlay.astro
---
<section id="call-overlay" class="hidden">
	<div class="call-canvas">
		<div id="remote-video-container"></div>
		<div id="local-video-container">
			<video id="local-video" autoplay muted playsinline></video>
		</div>
		<div class="call-controls">
			<button class="control-btn" id="toggle-mic" title="Silenciar">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>
			</button>
			<button class="control-btn" id="toggle-cam" title="Apagar cámara">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>
			</button>
			<button class="control-btn" id="toggle-screen" title="Compartir pantalla">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
			</button>
			<button class="control-btn danger" id="btn-hangup" title="Colgar">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
			</button>
		</div>
	</div>
</section>

<style>
	#call-overlay {
		position: fixed;
		inset: 0;
		background: rgba(0,0,0,0.85);
		backdrop-filter: saturate(180%) blur(20px);
		z-index: 2000;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.call-canvas {
		width: 90vw;
		height: 85vh;
		background: #000;
		border-radius: 24px;
		position: relative;
		overflow: hidden;
		box-shadow: 0 20px 60px rgba(0,0,0,0.4);
	}
	#remote-video-container {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	:global(#remote-video-container video) {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	#local-video-container {
		position: absolute;
		bottom: 32px;
		right: 32px;
		width: 240px;
		height: 160px;
		background: #111;
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 8px 24px rgba(0,0,0,0.5);
		border: 1px solid rgba(255,255,255,0.1);
	}
	#local-video-container video {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transform: scaleX(-1); /* Mirror effect */
	}
	.call-controls {
		position: absolute;
		bottom: 32px;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 16px;
		background: rgba(30,30,30,0.6);
		padding: 12px 24px;
		border-radius: 40px;
		backdrop-filter: blur(20px);
	}
	.control-btn {
		width: 54px;
		height: 54px;
		border-radius: 50%;
		border: none;
		background: rgba(255,255,255,0.15);
		color: white;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.2s ease;
	}
	.control-btn:hover { background: rgba(255,255,255,0.25); transform: scale(1.05); }
	.control-btn.danger { background: #FF3B30; }
	.control-btn.danger:hover { background: #FF453A; }
	
	:global(.control-btn.disabled) {
		background: #FF3B30 !important;
		color: white;
	}
	
	.hidden { display: none !important; }
</style>
