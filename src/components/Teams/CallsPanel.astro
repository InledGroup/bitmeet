---
// CallsPanel.astro
---
<div id="view-calls" class="panel-container hidden">
    <div class="panel-header">
        <h2>Llamadas e Invitaciones</h2>
        <div class="header-actions">
            <button id="btn-clear-calls" class="icon-button" title="Limpiar historial">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18m-2 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
            </button>
        </div>
    </div>

    <div class="panel-content">
        <section class="calls-section">
            <h3>Invitaciones a Reuniones</h3>
            <div id="calendar-invitations-list" class="item-list">
                <div class="loading-state">Cargando invitaciones...</div>
            </div>
        </section>

        <section class="calls-section">
            <h3>Historial de Llamadas</h3>
            <div id="calls-history-list" class="item-list">
                <div class="loading-state">Cargando historial...</div>
            </div>
        </section>
    </div>
</div>

<style>
    .panel-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: white;
    }
    .panel-header {
        padding: 20px 24px;
        border-bottom: 1px solid var(--apple-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .panel-header h2 { font-size: 22px; font-weight: 700; margin: 0; }
    
    .panel-content {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 32px;
    }
    
    .calls-section h3 {
        font-size: 14px;
        text-transform: uppercase;
        color: var(--apple-text-secondary);
        letter-spacing: 0.5px;
        margin-bottom: 16px;
    }
    
    .item-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    /* Estilos para los items se inyectarán vía JS por simplicidad de este componente dinámico */
</style>
