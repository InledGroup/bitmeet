---
// ListPanel.astro
---
<section class="apple-list-panel">
	<div class="panel-header">
		<h2 id="panel-title">Chat</h2>
		<div class="header-actions">
			<button id="btn-new-group" class="icon-button" title="Nuevo Grupo">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
			</button>
			<button id="btn-new-chat" class="icon-button" title="Nueva conversación">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
			</button>
		</div>
	</div>
	
	<div class="search-container">
		<div class="search-wrapper">
			<svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
			<input type="text" id="global-search" placeholder="Buscar usuarios..." autocomplete="off" />
		</div>
	</div>

	<div id="chats-list" class="chats-scrollable">
		<div class="loading-state">Cargando identidad...</div>
	</div>
	
	<div id="search-results" class="chats-scrollable hidden"></div>
</section>

<style>
	.apple-list-panel {
		width: 320px;
		background: var(--apple-bg);
		border-right: 1px solid var(--apple-border);
		display: flex;
		flex-direction: column;
		z-index: 90;
	}

	.panel-header {
		padding: 24px 20px 12px;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.header-actions { display: flex; gap: 4px; }
	.panel-header h2 { font-size: 24px; font-weight: 700; letter-spacing: -0.01em; }
	.icon-button {
		background: transparent;
		border: none;
		color: var(--apple-accent);
		cursor: pointer;
		padding: 8px;
		border-radius: 50%;
		transition: all 0.2s;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.icon-button:hover { background: rgba(0, 122, 255, 0.1); }

	.search-container { padding: 8px 16px 16px; }
	.search-wrapper {
		position: relative;
		display: flex;
		align-items: center;
		background: #E3E3E8;
		border-radius: 10px;
		transition: all 0.2s;
	}
	.search-wrapper:focus-within { 
		background: #FFFFFF;
		box-shadow: 0 0 0 2px var(--apple-accent); 
	}
	.search-icon { position: absolute; left: 12px; color: #86868B; pointer-events: none; }
	.search-wrapper input {
		width: 100%;
		padding: 8px 12px 8px 34px;
		border: none;
		outline: none;
		font-size: 15px;
		background: transparent;
	}

	.chats-scrollable { flex: 1; overflow-y: auto; padding: 0 10px; }
	/* Estilos inyectados desde el script principal */
	:global(.chat-item) {
		display: flex;
		gap: 12px;
		padding: 10px 12px;
		cursor: pointer;
		transition: background 0.2s;
		border-radius: 10px;
		margin-bottom: 2px;
		position: relative;
	}
	:global(.chat-item:hover) { background: #E5E5EA; }
	:global(.chat-item.active) { background: #007AFF; color: white; }
	:global(.chat-item.active .chat-row), :global(.chat-item.active .preview) { color: rgba(255,255,255,0.9) !important; }
	
	:global(.chat-avatar) {
		width: 46px;
		height: 46px;
		background: #D1D1D6;
		color: #1D1D1F;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 600;
		font-size: 18px;
		flex-shrink: 0;
	}
	:global(.chat-info) { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: center; }
	:global(.chat-row) { display: flex; justify-content: space-between; align-items: center; gap: 8px; }
	:global(.chat-row strong) { font-size: 15px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
	:global(.preview) { font-size: 13px; color: #86868B; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 2px; }
	:global(.preview.unread) { font-weight: 700; color: var(--apple-text); }

	.loading-state { padding: 40px; text-align: center; color: #86868B; font-size: 14px; }
	:global(.empty-results) { padding: 40px; text-align: center; color: #86868B; }
</style>
