---
// ChatArea.astro
import EmojiPickerWrapper from './EmojiPickerWrapper';
---
<section class="apple-content">
	<!-- Vista: Sin chat seleccionado -->
	<div id="view-no-chat" class="content-view-centered">
		<div class="welcome-hero">
			<div class="hero-illustration">
				<svg width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="var(--apple-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.8;">
					<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
				</svg>
			</div>
			<h1>Te damos la bienvenida, <span id="welcome-name">...</span></h1>
			<p>Selecciona un chat de la lista o busca a alguien para empezar a colaborar de forma 100% privada y P2P.</p>
			<button class="apple-button secondary" id="btn-hero-new-chat">Nueva conversación</button>
		</div>
	</div>

	<!-- Vista: Chat Activo -->
	<div id="view-active-chat" class="chat-viewport hidden">
		<div class="chat-header-main">
			<div class="recipient-info">
				<div class="name-row">
					<h3 id="active-chat-name">Nombre</h3>
					<button id="btn-toggle-contact" class="star-btn" title="Guardar contacto">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
					</button>
				</div>
				<div class="status-wrapper">
					<span class="status-dot offline" id="active-chat-status-dot"></span>
					<span id="active-chat-status">Desconectado</span>
				</div>
			</div>
			<div class="header-actions" id="active-chat-actions">
				<div id="unknown-user-actions" class="unknown-actions hidden">
					<button class="apple-button small secondary" id="btn-block-user">Bloquear</button>
					<button class="apple-button small" id="btn-save-contact">Guardar</button>
				</div>
				<button class="call-btn" id="btn-call-voice" title="Llamada de voz">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
				</button>
				<button class="call-btn primary" id="btn-call-video" title="Videollamada">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>
				</button>
				<button class="call-btn" id="btn-group-settings" title="Ajustes de grupo">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
				</button>
			</div>
		</div>

		<div class="messages-container" id="messages-list"></div>

		<div class="chat-input-area">
			<div id="emoji-picker-container" class="emoji-picker-wrapper hidden">
				<EmojiPickerWrapper client:only="react" />
			</div>
			<form id="chat-form">
				<div class="input-wrapper">
					<input type="text" id="chat-input" placeholder="Mensaje..." autocomplete="off" />
					<div class="input-actions">
						<button type="button" id="btn-emoji" class="emoji-btn" title="Emojis">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M8 14s1.5 2 4 2 4-2 4-2"></path><line x1="9" y1="9" x2="9.01" y2="9"></line><line x1="15" y1="9" x2="15.01" y2="9"></line></svg>
						</button>
						<button type="button" id="btn-attach" class="attach-btn" title="Adjuntar archivo">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>
						</button>
						<input type="file" id="file-input" class="hidden" />
						<button type="submit" id="btn-send">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
						</button>
					</div>
				</div>
			</form>
		</div>
	</div>
</section>

<style>
	.apple-content {
		flex: 1;
		display: flex;
		flex-direction: column;
		background: #FFFFFF;
		position: relative;
	}

	.content-view-centered {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		padding: 40px;
	}
	.welcome-hero { max-width: 440px; animation: fadeInScale 0.5s cubic-bezier(0.25, 0.1, 0.25, 1); }
	@keyframes fadeInScale { from { opacity: 0; transform: scale(0.97); } to { opacity: 1; transform: scale(1); } }
	.hero-illustration { margin-bottom: 24px; }
	.welcome-hero h1 { font-size: 28px; font-weight: 700; margin-bottom: 12px; letter-spacing: -0.02em; }
	.welcome-hero p { font-size: 16px; color: var(--apple-text-secondary); line-height: 1.5; margin-bottom: 32px; }

	.chat-viewport {
		display: flex;
		flex-direction: column;
		height: 100%;
		animation: fadeIn 0.3s ease-out;
	}
	@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

	.chat-header-main {
		padding: 16px 24px;
		border-bottom: 1px solid var(--apple-border);
		display: flex;
		justify-content: space-between;
		align-items: center;
		background: rgba(255,255,255,0.85);
		backdrop-filter: saturate(180%) blur(20px);
		z-index: 10;
	}
	.recipient-info h3 { font-size: 17px; font-weight: 600; margin-bottom: 2px; }
	.name-row { display: flex; align-items: center; gap: 8px; }
	.star-btn {
		background: transparent;
		border: none;
		color: #86868B;
		cursor: pointer;
		padding: 2px;
		display: flex;
		transition: all 0.2s;
	}
	.star-btn:hover { color: #FF9500; }
	.star-btn.active { color: #FF9500; fill: #FF9500; }
	.status-wrapper { display: flex; align-items: center; gap: 6px; }
	.status-wrapper span { font-size: 13px; color: var(--apple-text-secondary); }

	.header-actions {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.unknown-actions {
		display: flex;
		gap: 8px;
		margin-right: 12px;
		padding-right: 12px;
		border-right: 1px solid var(--apple-border);
	}

	.call-btn {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		border: none;
		background: #F5F5F7;
		color: var(--apple-accent);
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.2s;
	}
	.call-btn:hover { background: #E5E5EA; }
	.call-btn.primary { background: var(--apple-accent); color: white; }
	.call-btn.primary:hover { background: #0062CC; }

	.messages-container {
		flex: 1;
		padding: 24px 32px;
		overflow-y: auto;
		display: flex;
		flex-direction: column;
		gap: 8px;
		background: #FFFFFF;
	}

	:global(.message-bubble) {
		max-width: 65%;
		padding: 10px 14px;
		border-radius: 18px;
		font-size: 15px;
		line-height: 1.4;
		position: relative;
		word-break: break-word;
	}
	:global(.message-bubble.mine) {
		align-self: flex-end;
		background: var(--apple-accent);
		color: white;
		border-bottom-right-radius: 4px;
	}
	:global(.message-bubble.theirs) {
		align-self: flex-start;
		background: #F2F2F7;
		color: var(--apple-text);
		border-bottom-left-radius: 4px;
	}
	:global(.msg-sender) {
		font-size: 11px;
		font-weight: 700;
		color: var(--apple-accent);
		margin-bottom: 2px;
	}
	:global(.msg-meta) {
		font-size: 11px;
		opacity: 0.7;
		margin-top: 4px;
		display: flex;
		justify-content: flex-end;
		align-items: center;
		gap: 4px;
	}
	
	:global(.system-message) {
		align-self: center;
		margin: 12px 0;
		font-size: 13px;
		color: #86868B;
		font-style: italic;
		background: #F5F5F7;
		padding: 4px 16px;
		border-radius: 12px;
		text-align: center;
		max-width: 90%;
		word-break: break-all;
		line-height: 1.4;
	}

	:global(.message-bubble.file-message) {
		padding: 8px;
		min-width: 240px;
	}
	:global(.file-content) {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}
	:global(.file-preview) {
		width: 100%;
		border-radius: 12px;
		overflow: hidden;
		background: #000;
		aspect-ratio: 16/9;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	:global(.file-preview.loading) { background: #F2F2F7; }
	:global(.file-preview img) { width: 100%; height: 100%; object-fit: cover; cursor: pointer; }
	:global(.file-info) {
		display: flex;
		align-items: center;
		gap: 12px;
		padding: 8px;
		background: rgba(255,255,255,0.1);
		border-radius: 10px;
	}
	:global(.theirs .file-info) { background: rgba(0,0,0,0.05); }
	:global(.file-icon) { color: var(--apple-accent); }
	:global(.file-details) { flex: 1; overflow: hidden; }
	:global(.file-name) { font-size: 14px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
	:global(.file-size) { font-size: 11px; opacity: 0.7; }
	:global(.file-download-btn) {
		background: transparent;
		border: none;
		color: inherit;
		cursor: pointer;
		padding: 4px;
		border-radius: 50%;
		transition: background 0.2s;
	}
	:global(.file-download-btn:hover) { background: rgba(0,0,0,0.1); }
	:global(.file-progress) { font-size: 11px; text-align: center; opacity: 0.8; }

	.chat-input-area {
		padding: 16px 24px 24px;
		background: #FFFFFF;
		position: relative;
	}
	.input-wrapper {
		display: flex;
		align-items: center;
		background: #FFFFFF;
		border: 1px solid var(--apple-border);
		border-radius: 24px;
		padding: 4px 8px 4px 20px;
		transition: border-color 0.2s, box-shadow 0.2s;
	}
	.input-wrapper:focus-within {
		border-color: var(--apple-accent);
	}
	.input-wrapper input {
		flex: 1;
		border: none;
		outline: none;
		padding: 12px 0;
		font-size: 15px;
		background: transparent;
	}
	.input-actions { display: flex; align-items: center; gap: 8px; padding-left: 8px; }
	.attach-btn {
		background: transparent;
		border: none;
		color: #86868B;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 4px;
		transition: color 0.2s;
	}
	.attach-btn:hover { color: var(--apple-accent); }
	#btn-send {
		background: var(--apple-accent);
		color: white;
		border: none;
		width: 32px;
		height: 32px;
		border-radius: 50%;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: transform 0.2s, opacity 0.2s;
	}
	#btn-send:hover { transform: scale(1.05); }
	#btn-send:active { transform: scale(0.95); }
	#btn-send:disabled { opacity: 0.3; cursor: default; }

	.emoji-btn {
		background: transparent;
		border: none;
		color: #86868B;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 4px;
		transition: color 0.2s;
	}
	.emoji-btn:hover { color: var(--apple-accent); }

	.emoji-picker-wrapper {
		position: absolute;
		bottom: 90px;
		right: 30px;
		z-index: 1000;
		box-shadow: 0 12px 40px rgba(0,0,0,0.12);
		border-radius: 16px;
		overflow: hidden;
		background: rgba(255, 255, 255, 0.8);
		backdrop-filter: blur(20px) saturate(180%);
		border: 1px solid rgba(0,0,0,0.1);
		transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s;
		width: 320px;
	}
	.emoji-picker-wrapper.hidden {
		display: none;
		opacity: 0;
		transform: translateY(10px) scale(0.95);
	}
	.emoji-picker-wrapper:not(.hidden) {
		display: block;
		opacity: 1;
		transform: translateY(0) scale(1);
	}

	/* Contenedor del picker de Frimousse */
	.frimousse-picker-container {
		display: flex;
		flex-direction: column;
		height: 420px;
	}
</style>

<script>
	function initEmojiPicker() {
		const emojiBtn = document.getElementById('btn-emoji');
		const pickerContainer = document.getElementById('emoji-picker-container');
		const chatInput = document.getElementById('chat-input') as HTMLInputElement;

		if (!emojiBtn || !pickerContainer || !chatInput) return;

		// Mostrar/Ocultar picker
		emojiBtn.addEventListener('click', (e) => {
			e.stopPropagation();
			pickerContainer.classList.toggle('hidden');
		});

		// Escuchar selección de emoji desde el componente React
		window.addEventListener('emoji-selected', (e: any) => {
			const emoji = e.detail;
			const start = chatInput.selectionStart || 0;
			const end = chatInput.selectionEnd || 0;
			const text = chatInput.value;
			
			// Insertar en la posición del cursor
			chatInput.value = text.substring(0, start) + emoji + text.substring(end);
			
			// Reposicionar cursor
			const newPos = start + emoji.length;
			chatInput.setSelectionRange(newPos, newPos);
			
			chatInput.focus();
			// Opcional: Cerrar al seleccionar
			// pickerContainer.classList.add('hidden');
		});

		// Cerrar al hacer clic fuera
		document.addEventListener('click', (e) => {
			if (!pickerContainer.contains(e.target as Node) && e.target !== emojiBtn) {
				pickerContainer.classList.add('hidden');
			}
		});
	}

	// Ejecutar en carga y en transiciones de Astro
	document.addEventListener('astro:page-load', initEmojiPicker);
	initEmojiPicker();
</script>