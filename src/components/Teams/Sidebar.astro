---
// Sidebar.astro
---
<aside class="apple-sidebar">
	<div class="sidebar-top">
		<div class="sidebar-icon active" title="Chat" data-view="chat">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
		</div>
		<div class="sidebar-icon" title="Llamadas" data-view="calls">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
		</div>
		<div class="sidebar-icon" title="Equipos" data-view="teams">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
		</div>
	</div>
	<div class="sidebar-bottom">
		<div class="sidebar-icon" id="btn-open-settings" title="Ajustes de Notificaciones">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
		</div>
		<div class="sidebar-icon profile-trigger" id="btn-logout" title="Cerrar sesión">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
		</div>
		<div class="sidebar-icon profile-trigger" style="pointer-events: none;">
			<div class="status-circle offline"></div>
		</div>
	</div>
</aside>

<style>
	.apple-sidebar {
		width: 70px;
		background: var(--sidebar-bg);
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		align-items: center;
		padding: 16px 0;
		z-index: 100;
		border-right: 1px solid var(--apple-border);
		box-shadow: 1px 0 10px rgba(0,0,0,0.02);
	}
	.sidebar-icon {
		width: 44px;
		height: 44px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--apple-text-secondary);
		cursor: pointer;
		margin-bottom: 12px;
		border-radius: 12px;
		transition: all 0.2s ease;
	}
	.sidebar-icon:hover { 
		background: rgba(0,0,0,0.05); 
		color: var(--apple-text);
	}
	.sidebar-icon.active { 
		color: var(--apple-accent);
		background: #FFFFFF;
		box-shadow: 0 2px 5px rgba(0,0,0,0.05);
	}
	.status-circle { width: 10px; height: 10px; border-radius: 50%; }
	.status-circle.offline { background: #86868B; }
	.status-circle.online { background: #34C759; box-shadow: 0 0 8px rgba(52,199,89,0.5); }
</style>
