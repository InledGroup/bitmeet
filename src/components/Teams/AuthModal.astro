---
// AuthModal.astro
---
<section id="auth-overlay" class="auth-overlay">
	<div class="auth-card" id="auth-card">
		<div class="auth-header">
			<img src="https://hosted.inled.es/bitid-animated.gif" alt="BitID Logo" class="apple-id-logo" crossorigin="anonymous" />
			<h1 id="auth-title">BitID</h1>
		</div>
		
		<div id="auth-unlock-view" class="auth-view hidden">
			<p class="auth-subtitle">Inicia sesión con tu BitID para acceder a BitMeet.</p>
			<div class="apple-input-wrapper">
				<input type="password" id="master-password" placeholder="Contraseña Maestra" autofocus />
				<button id="btn-unlock-app" class="arrow-submit-btn">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
				</button>
			</div>
			<div style="margin-top: 16px;">
				<a href="#" style="color: #0066cc; text-decoration: none; font-size: 14px;">¿Olvidaste la contraseña?</a>
			</div>
		</div>
		
		<div id="auth-import-view" class="auth-view hidden">
			<p class="auth-subtitle">Bienvenido! No hemos encontrado tu passkey en la memoria de tu dispositivo. Impórtala o sincronízala con otro dispositivo.</p>

			<div class="auth-import-actions">
				<button id="btn-trigger-import" class="apple-button-primary">Importar BitID (.json)</button>
				<input type="file" id="import-file" class="hidden" accept=".json" />

				<div class="auth-divider">o mediante código / QR</div>

				<div class="apple-sync-row">
					<div class="sync-input-wrapper">
						<input type="text" id="pairing-code-input" placeholder="Código de 6 dígitos" maxlength="6" />
						<button id="btn-sync-by-code" class="apple-arrow-button" title="Confirmar código">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</button>
					</div>
					<button id="btn-scan-qr" class="apple-qr-button" title="Escanear código QR">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="3" y="3" width="7" height="7" rx="1.5"></rect>
							<rect x="14" y="3" width="7" height="7" rx="1.5"></rect>
							<rect x="14" y="14" width="7" height="7" rx="1.5"></rect>
							<rect x="3" y="14" width="7" height="7" rx="1.5"></rect>
						</svg>
					</button>
				</div>
				<div id="qr-reader-container" class="hidden apple-qr-scanner-container">
					<div id="qr-reader"></div>
					<button id="btn-close-qr" class="apple-button-text">Cancelar Escaneo</button>
				</div>
			</div>

			<p style="margin-top: 32px; font-size: 12px; color: #86868b;">Si no tienes un ID, créalo en <a href="https://id.inled.es" target="_blank" style="color: #0066cc; text-decoration: none;">id.inled.es</a></p>
		</div>
	</div>
</section>

<style>
	.apple-sync-row {
		display: flex;
		gap: 12px;
		width: 100%;
		align-items: center;
	}

	.sync-input-wrapper {
		position: relative;
		flex: 1;
	}

	.sync-input-wrapper input {
		width: 100% !important;
		padding: 12px 48px 12px 16px !important;
		border-radius: 14px !important;
		border: 1px solid #d2d2d7 !important;
		font-size: 16px !important;
		background: #f5f5f7 !important;
		color: #1d1d1f !important;
		outline: none !important;
		transition: all 0.2s ease;
		font-weight: 500;
	}

	.sync-input-wrapper input:focus {
		background: #fff !important;
		border-color: #0071e3 !important;
		box-shadow: 0 0 0 4px rgba(0, 113, 227, 0.1) !important;
	}

	.apple-arrow-button {
		position: absolute;
		right: 6px;
		top: 50%;
		transform: translateY(-50%);
		background: #0071e3;
		color: white;
		border: none;
		width: 32px;
		height: 32px;
		border-radius: 50%;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.2s;
	}

	.apple-arrow-button:hover {
		background: #0077ed;
		transform: translateY(-50%) scale(1.05);
	}

	.apple-qr-button {
		width: 44px;
		height: 44px;
		background: #f5f5f7;
		border: none;
		color: #0071e3;
		border-radius: 14px;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition: all 0.2s;
	}

	.apple-qr-button:hover {
		background: #e8e8ed;
		color: #0077ed;
	}

	.apple-qr-scanner-container {
		width: 100%;
		margin-top: 16px;
		border-radius: 20px;
		overflow: hidden;
		background: #000;
		box-shadow: 0 10px 30px rgba(0,0,0,0.15);
		display: flex;
		flex-direction: column;
		align-items: center;
		padding-bottom: 12px;
	}

	#qr-reader {
		width: 100% !important;
		border: none !important;
	}

	.apple-button-text {
		background: transparent;
		border: none;
		color: #0071e3;
		font-size: 14px;
		font-weight: 500;
		cursor: pointer;
		padding: 8px 16px;
		margin-top: 8px;
	}

	/* Ocultar botones internos de html5-qrcode que son feos */
	#qr-reader button {
		background: #0071e3 !important;
		color: white !important;
		border: none !important;
		border-radius: 8px !important;
		padding: 8px 16px !important;
		font-family: inherit !important;
		font-weight: 600 !important;
		cursor: pointer !important;
	}

	#qr-reader __dashboard_section_csr_button {
		display: none !important;
	}
			</div>

			<p style="margin-top: 32px; font-size: 12px; color: #86868b;">Si no tienes un ID, créalo en <a href="https://id.inled.es" target="_blank" style="color: #0066cc; text-decoration: none;">id.inled.es</a></p>
		</div>

		<div id="auth-sync-progress-view" class="auth-view hidden" style="text-align: center;">
			<div style="margin-bottom: 24px;">
				<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#0071e3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="spin-animation">
					<path d="M21 12a9 9 0 1 1-6.219-8.56"/>
				</svg>
			</div>
			<h2 style="font-size: 20px; font-weight: 600; color: #1d1d1f; margin-bottom: 8px;">Sincronizando historial...</h2>
			<p id="sync-progress-text" style="font-size: 14px; color: #86868b; margin-bottom: 24px;">Conectando con tu otro dispositivo...</p>

			<div style="width: 100%; height: 6px; background: #e5e5ea; border-radius: 3px; overflow: hidden;">
				<div id="sync-progress-bar" style="height: 100%; width: 0%; background: #0071e3; transition: width 0.3s ease;"></div>
			</div>

			<div style="display: flex; flex-direction: column; gap: 12px; margin-top: 32px;">
				<button id="btn-skip-sync" class="apple-button-secondary" style="width: 100%;">Omitir y entrar ahora</button>
				<button id="btn-cancel-sync" style="background: none; border: none; color: #ff3b30; font-size: 14px; cursor: pointer; font-weight: 500;">Cancelar sincronización</button>
			</div>
		</div>	</div>
</section>

<style>
	.auth-import-actions {
		display: flex;
		flex-direction: column;
		gap: 16px;
		margin-top: 24px;
	}

	.auth-divider {
		text-align: center;
		position: relative;
		font-size: 13px;
		color: #86868b;
		margin: 8px 0;
	}

	.auth-divider::before,
	.auth-divider::after {
		content: "";
		position: absolute;
		top: 50%;
		width: 30%;
		height: 1px;
		background: #d2d2d7;
	}

	.auth-divider::before { left: 0; }
	.auth-divider::after { right: 0; }

	.sync-input-group {
		position: relative;
		width: 100%;
	}

	.sync-input-group input {
		width: 100% !important;
		padding: 14px 44px 14px 16px !important;
		border-radius: 12px !important;
		border: 1px solid #d2d2d7 !important;
		font-size: 17px !important;
		background: #fff !important;
		color: #1d1d1f !important;
		outline: none !important;
		text-align: center;
		letter-spacing: 2px;
		font-weight: 600;
	}

	.sync-input-group input:focus {
		border-color: #0071e3 !important;
		box-shadow: 0 0 0 4px rgba(0, 113, 227, 0.1) !important;
	}

	.apple-button-arrow {
		position: absolute;
		right: 8px;
		top: 50%;
		transform: translateY(-50%);
		background: #0071e3;
		color: white;
		border: none;
		width: 30px;
		height: 30px;
		border-radius: 50%;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0;
		transition: transform 0.2s, background 0.2s;
	}

	.apple-button-arrow:hover {
		background: #0077ed;
		transform: translateY(-50%) scale(1.05);
	}

	@keyframes spin {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}
	.spin-animation {
		animation: spin 1s linear infinite;
	}
</style>
