---
// AuthModal.astro
---
<section id="auth-overlay" class="auth-overlay">
	<div class="auth-card" id="auth-card">
		<div class="auth-header">
			<img src="https://hosted.inled.es/bitid-animated.gif" alt="BitID Logo" class="apple-id-logo" />
			<h1 id="auth-title">BitSuite Identity</h1>
		</div>
		
		<div id="auth-unlock-view" class="auth-view hidden">
			<p class="auth-subtitle">Inicia sesión con tu BitID para acceder a Teams.</p>
			<div class="apple-input-wrapper">
				<input type="password" id="master-password" placeholder="Contraseña Maestra" autofocus />
				<button id="btn-unlock-app" class="arrow-submit-btn">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
				</button>
			</div>
			<div style="margin-top: 16px;">
				<a href="#" style="color: #0066cc; text-decoration: none; font-size: 14px;">¿Olvidaste la contraseña?</a>
			</div>
		</div>
		
		<div id="auth-import-view" class="auth-view hidden">
			<p class="auth-subtitle">No se ha encontrado ninguna identidad local.</p>
			<button id="btn-trigger-import" class="apple-button-primary">Importar BitID (.json)</button>
			<input type="file" id="import-file" class="hidden" accept=".json" />
			<p style="margin-top: 32px; font-size: 12px; color: #86868b;">Si no tienes un ID, créalo en <a href="https://id.inled.es" target="_blank" style="color: #0066cc; text-decoration: none;">id.inled.es</a></p>
		</div>
	</div>
</section>
