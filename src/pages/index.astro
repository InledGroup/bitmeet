	btnAttach?.addEventListener("click", () => fileInput?.click());
	fileInput?.addEventListener("change", async (e: any) => {
		const file = e.target.files[0];
		if (!file || !currentChatId) return;

		const isGroup = currentChatType === "group";
		if (!isGroup && !currentChatPubKey) return;

		// 1. Cifrar archivo
		const key = await generateFileKey();
		const { iv, data } = await encryptFile(file, key);
		const keyStr = await exportFileKey(key);
		const ivStr = btoa(String.fromCharCode(...iv));

		// 2. Iniciar WebTorrent
		if (!torrentClient) torrentClient = await getWebTorrentClient();
		const encryptedBlob = new Blob([data], {
			type: "application/octet-stream",
		});

		torrentClient.seed(
			encryptedBlob,
			{
				name: file.name + ".encrypted",
				announce: TRACKERS,
			},
			async (torrent: any) => {
				const timestamp = Date.now();
				const msgId = Math.random().toString(36).substring(7);

				// GUARDAR EN INDEXEDDB PARA AUTO-RESEEDING
				try {
					await chatRepo.saveFileData(msgId, data, torrent.magnetURI);
				} catch (e) {}

				const fileMetadata = {
					name: file.name,
					size: file.size,
					type: file.type,
					magnetURI: torrent.magnetURI,
					iv: ivStr,
					key: keyStr,
				};

				const { ciphertext, iv: msgIv } = await encryptText(
					JSON.stringify(fileMetadata),
					currentChatId!,
				);

				const rawMessage: any = {
					id: msgId,
					senderPubKey: myIdentity.publicKey,
					senderUsername: myIdentity.username,
					content: JSON.stringify(fileMetadata),
					timestamp,
					type: "file",
					status: "pending",
					iv: msgIv,
				};

				if (isGroup) {
					rawMessage.groupId = currentChatId;
				} else {
					rawMessage.receiverPubKey = currentChatPubKey;
				}

				renderMessage(rawMessage);
				scrollToBottom();

				const p2pPayload = {
					type: "chat",
					msgType: "file",
					id: msgId,
					senderPubKey: myIdentity.publicKey,
					senderUsername: myIdentity.username,
					receiverPubKey: !isGroup ? currentChatPubKey : undefined,
					content: ciphertext,
					timestamp,
					iv: msgIv,
					groupId: isGroup ? currentChatId : undefined,
				};

				if (isGroup) {
					const others = currentGroupParticipants.filter(
						(p) => p !== myIdentity.publicKey,
					);
					let sentCount = 0;
					await Promise.all(
						others.map(async (pubKey) => {
							try {
								await p2p.sendP2PMessage(pubKey, p2pPayload);
								sentCount++;
							} catch (err) {}
						}),
					);
					if (sentCount > 0) {
						rawMessage.status = "sent";
						updateMessageUIStatus(msgId, "sent");
					}
				} else {
					try {
						await p2p.sendP2PMessage(
							currentChatPubKey!,
							p2pPayload,
						);
						rawMessage.status = "sent";
						updateMessageUIStatus(msgId, "sent");
					} catch (err) {}
				}

				await chatRepo.addMessage(currentChatId!, rawMessage);
				loadContacts();
			},
		);

		fileInput.value = "";
	});

	document
		.getElementById("chat-form")
		?.addEventListener("submit", async (e) => {
			e.preventDefault();
			const input = document.getElementById(
				"chat-input",
			) as HTMLInputElement;
			const text = input.value.trim();
			if (!text || !currentChatId) return;

			const isGroup = currentChatType === "group";
			if (!isGroup && !currentChatPubKey) return;

			input.value = "";
			const timestamp = Date.now();
			const msgId = Math.random().toString(36).substring(7);
			const { ciphertext, iv } = await encryptText(text, currentChatId);

			const rawMessage: any = {
				id: msgId,
				senderPubKey: myIdentity.publicKey,
				senderUsername: myIdentity.username,
				content: text,
				timestamp,
				status: "pending",
				iv,
			};

			if (isGroup) {
				rawMessage.groupId = currentChatId;
			} else {
				rawMessage.receiverPubKey = currentChatPubKey;
			}

			renderMessage(rawMessage);
			scrollToBottom();

			const p2pPayload = {
				type: "chat",
				msgType: "text",
				id: msgId,
				senderPubKey: myIdentity.publicKey,
				senderUsername: myIdentity.username,
				receiverPubKey: !isGroup ? currentChatPubKey : undefined,
				content: ciphertext,
				timestamp,
				iv,
				groupId: isGroup ? currentChatId : undefined,
			};

			const targets = isGroup
				? currentGroupParticipants.filter(
						(p) => p !== myIdentity.publicKey,
					)
				: [currentChatPubKey!];

			let sentToRecipient = false;
			await Promise.all(
				targets.map(async (pubKey) => {
					try {
						await p2p.sendP2PMessage(pubKey, p2pPayload);
						sentToRecipient = true;
					} catch (err) {
						console.warn(`Could not send message to ${pubKey}`);
					}
				}),
			);

			// Sincronización en tiempo real con mis otros dispositivos
			p2p.sendP2PMessage(myIdentity.publicKey, p2pPayload).catch(() => {});

			if (sentToRecipient) {
				rawMessage.status = "sent";
				updateMessageUIStatus(msgId, "sent");
			}

			await chatRepo.addMessage(currentChatId, rawMessage);
			loadContacts(); // Refrescar para mover al principio
		});
	document
		.getElementById("btn-hero-new-chat")
		?.addEventListener("click", () => {
			globalSearch?.focus();
		});

	// Logout
	document.getElementById("btn-logout")?.addEventListener("click", () => {
		bitid.lock();
		window.location.reload();
	});

	async function getChatId(pub1: string, pub2: string) {
		const combined = [pub1, pub2].sort().join("-");
		const msgUint8 = new TextEncoder().encode(combined);
		const hashBuffer = await crypto.subtle.digest("SHA-256", msgUint8);
		const hashArray = Array.from(new Uint8Array(hashBuffer));
		return hashArray
			.map((b) => b.toString(16).padStart(2, "0"))
			.join("")
			.substring(0, 16);
	}

	initApp();
</script>
