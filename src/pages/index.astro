	async function loadFilePreview(msgId: string) {
		const msgEl = document.querySelector(
			`.message-bubble[data-id="${msgId}"]`,
		);
		const previewContainer = msgEl?.querySelector(".file-preview");
		if (!previewContainer) return;

		try {
			const chat = await chatRepo.getChat(currentChatId!);
			const msg = chat?.messages.find((m) => m.id === msgId);
			if (!msg || msg.type !== "file") return;

			const fileMeta = JSON.parse(msg.content);
			if (!fileMeta.type.startsWith("image/")) return;

			if (!torrentClient) torrentClient = await getWebTorrentClient();

			const onDone = async (t: any) => {
				try {
					const file = t.files[0];
					const encryptedBuf = await file.arrayBuffer();

					// GUARDAR PARA RE-SEEDING FUTURO
					try {
						await chatRepo.saveFileData(
							msgId,
							encryptedBuf,
							fileMeta.magnetURI,
						);
					} catch (e) {}

					const key = await importFileKey(fileMeta.key);
					const iv = new Uint8Array(
						atob(fileMeta.iv)
							.split("")
							.map((c) => c.charCodeAt(0)),
					);

					const decryptedBuf = await decryptFile(
						encryptedBuf,
						key,
						iv,
					);
					const blob = new Blob([decryptedBuf], {
						type: fileMeta.type,
					});
					const url = URL.createObjectURL(blob);
					previewContainer.innerHTML = `<img src="${url}" alt="Preview" class="preview-img" onclick="window.open('${url}', '_blank')" />`;
					previewContainer.classList.remove("loading");
				} catch (e) {
					console.error("Preview decryption error:", e);
				}
			};

			let torrent = torrentClient.torrents.find(
				(t: any) =>
					t.magnetURI === fileMeta.magnetURI ||
					t.infoHash === fileMeta.magnetURI ||
					t.infoHash ===
						fileMeta.magnetURI.split("btih:")[1]?.split("&")[0],
			);

			if (torrent && typeof torrent.on === "function") {
				if (torrent.done) onDone(torrent);
				else torrent.on("done", () => onDone(torrent));
			} else {
				try {
					torrentClient.add(
						fileMeta.magnetURI,
						{ announce: TRACKERS },
						(t: any) => {
							if (t && typeof t.on === "function")
								t.on("done", () => onDone(t));
						},
					);
				} catch (e) {
					const retry = torrentClient.get(fileMeta.magnetURI);
					if (retry && typeof retry.on === "function") onDone(retry);
				}
			}
		} catch (e) {
			console.error("Preview load error:", e);
		}
	}

	function formatMessageText(text: string) {
		if (!text) return "";
		// Escapar HTML para evitar XSS
		const escaped = text
			.replace(/&/g, "&amp;")
			.replace(/</g, "&lt;")
			.replace(/>/g, "&gt;");

		// Regex para URLs: http/https o cualquier cosa con patrón letra.letra (dominios)
		// Detectamos dominios como google.com o incluso a.b
		const urlRegex =
			/(https?:\/\/[^\s]+)|(\b[a-zA-Z0-9-]+\.[a-zA-Z]{2,}(?:\/[^\s]*)?\b)/g;

		return escaped.replace(urlRegex, (match) => {
			let url = match;
			if (!url.startsWith("http")) {
				url = "https://" + url;
			}
			return `<a href="${url}" class="msg-link" onclick="handleLinkClick(event)" ondblclick="handleLinkDblClick(event)">${match}</a>`;
		});
	}

