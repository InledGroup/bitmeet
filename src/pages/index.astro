				</div>
			`,
				)
				.join("");

			container.querySelectorAll("button").forEach((btn) => {
				btn.addEventListener("click", () => {
					const pubKey = btn.getAttribute("data-pubkey");
					selectedParticipants = selectedParticipants.filter(
						(p) => p.pubKey !== pubKey,
