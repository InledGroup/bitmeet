	async function loadContacts() {
		const savedContacts = await chatRepo.listContacts();
		const activeChats = await chatRepo.listAllChats();
		const colleagues = await bitid.getColleagues();
		
		// Filtrar bloqueados
		const filteredSaved = savedContacts.filter(c => !c.isBlocked);

		// Fusionar listas de contactos directos
		const directContacts: any[] = [...filteredSaved];
		
		colleagues.forEach(c => {
			const existing = directContacts.find(a => a.publicKey === c.public_key);
			if (!existing) {
				directContacts.push({ publicKey: c.public_key, username: c.username, online_status: c.online_status });
			} else {
				existing.online_status = c.online_status;
			}
		});

		// Grupos y chats activos
		const groups: any[] = [];
		const otherDirects: any[] = [];

		for (const chat of activeChats) {
			if (chat.type === 'group') {
				groups.push({
					id: chat.id,
					username: chat.name || "Grupo sin nombre",
					isGroup: true,
					participants: chat.participants,
					lastUpdate: chat.lastUpdate
				});
				continue;
			}

			const otherPubKey = chat.participants.find(p => p !== myIdentity.publicKey);
			if (!otherPubKey) continue;

			const existing = directContacts.find(a => a.publicKey === otherPubKey);
			const contact = await chatRepo.getContact(otherPubKey);
			if (contact?.isBlocked) continue;

			if (!existing) {
				// Buscar el mejor nombre posible del historial de este chat
				const otherMsgWithName = [...chat.messages].reverse().find(m => m.senderPubKey === otherPubKey && (m as any).senderUsername);
				const displayName = contact?.username || (otherMsgWithName as any)?.senderUsername || `Desconocido (${otherPubKey.substring(0, 6)})`;

				otherDirects.push({ 
					publicKey: otherPubKey, 
					username: displayName,
					isNew: true,
					lastUpdate: chat.lastUpdate
				});
			} else {
				// Si ya existía pero el nombre era Desconocido, intentar mejorar el nombre
				if (existing.username.includes('Desconocido')) {
					const otherMsgWithName = [...chat.messages].reverse().find(m => m.senderPubKey === otherPubKey && (m as any).senderUsername);
					if (otherMsgWithName) existing.username = (otherMsgWithName as any).senderUsername;
				}
				existing.lastUpdate = chat.lastUpdate;
			}
		}

		// Ordenar todo por última actividad
		const all = [...groups, ...directContacts, ...otherDirects].sort((a, b) => (b.lastUpdate || 0) - (a.lastUpdate || 0));

		// Actualizar estados de conexión en tiempo real solo para directos
		await Promise.all(all.filter(c => !c.isGroup).map(async c => {
			const isConnected = await p2p.isConnected(c.publicKey);
			if (isConnected) {
				c.online_status = 'online';
			} else {
				// Consultar presencia global si no hay P2P activo
				c.online_status = await p2p.getPresence(c.publicKey);
			}
		}));

		renderContactList(all);
	}

	// Refresco periódico de estados cada 10 segundos
	setInterval(() => {
		loadContacts();
		retryPendingMessages();
	}, 10000);

	async function loadColleagues() {
		const colleagues = await bitid.getColleagues();
		renderContactList(colleagues.map(c => ({ publicKey: c.public_key, username: c.username, online_status: c.online_status })));
	}

	function renderContactList(list: any[]) {
		if (chatsList) {
			if (list.length === 0) {
				chatsList.innerHTML = '<div class="empty-results">No hay contactos</div>';
				return;
			}
			chatsList.innerHTML = list.map(c => `
				<div class="chat-item ${c.isNew ? 'new-chat' : ''} ${c.isGroup ? 'group-item' : ''}" 
					 data-id="${c.isGroup ? c.id : c.publicKey}" 
					 data-type="${c.isGroup ? 'group' : 'direct'}">
					<div class="chat-avatar ${c.isGroup ? 'group-avatar' : ''}">${c.username.charAt(0).toUpperCase()}</div>
					<div class="chat-info">
						<div class="chat-row">
							<strong>${c.isGroup ? '👥 ' : ''}${c.username}</strong> 
							${c.online_status ? `<span class="status-dot ${c.online_status === 'online' ? 'online' : 'offline'}"></span>` : ''}
						</div>
						<div class="preview">${c.isGroup ? `${c.participants.length} participantes` : (c.isNew ? 'Nuevo mensaje' : (c.online_status === 'online' ? 'Disponible' : 'Desconectado'))}</div>
					</div>
				</div>
			`).join('');

			chatsList.querySelectorAll('.chat-item').forEach(item => {
				item.addEventListener('click', async (e) => {
					const target = e.currentTarget as HTMLElement;
					const id = target.getAttribute('data-id');
					const type = target.getAttribute('data-type') as 'direct' | 'group';
					const name = target.querySelector('strong')?.textContent?.replace('👥 ', '');
					await selectChat(id!, name!, type);
				});
			});
		}
	}

	async function selectChat(id: string, name: string, type: 'direct' | 'group' = 'direct') {
		viewNoChat?.classList.add('hidden');
		viewActiveChat?.classList.remove('hidden');
		document.querySelectorAll('.chat-item').forEach(i => i.classList.remove('active'));
		
		const selector = type === 'group' ? `[data-id="${id}"]` : `[data-id="${id}"]`;
		const item = document.querySelector(selector);
		item?.classList.remove('unread');
		item?.classList.add('active');
		
		document.getElementById('active-chat-name')!.textContent = name;
		currentChatType = type;

		const statusEl = document.getElementById('active-chat-status')!;
		const statusDot = document.getElementById('active-chat-status-dot')!;
		const btnVoice = document.getElementById('btn-call-voice');
		const btnVideo = document.getElementById('btn-call-video');
		const btnGSettings = document.getElementById('btn-group-settings');
		
		if (type === 'group') {
			currentChatId = id;
			currentChatPubKey = null;
			const chat = await chatRepo.getChat(id);
			currentGroupParticipants = chat?.participants || [];
			currentGroupOwner = chat?.owner || null;
			
			console.log("[BitMeet] Seleccionado grupo:", name, "ID:", id);
			console.log("[BitMeet] Owner del grupo:", currentGroupOwner);
			console.log("[BitMeet] Mi clave pública:", myIdentity?.publicKey);
			console.log("[BitMeet] ¿Es admin?:", currentGroupOwner === myIdentity?.publicKey);

			statusEl.textContent = `${currentGroupParticipants.length} participantes`;
			statusDot.className = 'status-dot online';
			
			if (btnVoice) btnVoice.classList.add('hidden');
			if (btnVideo) btnVideo.classList.add('hidden');
			if (btnGSettings) {
				btnGSettings.classList.remove('hidden');
				console.log("[BitMeet] Mostrando botón de ajustes de grupo");
			}
		} else {
			currentChatId = await getChatId(myIdentity.publicKey, id);
			currentChatPubKey = id;
			currentGroupParticipants = [];
			currentGroupOwner = null;

			if (btnVoice) btnVoice.classList.remove('hidden');
			if (btnVideo) btnVideo.classList.remove('hidden');
			if (btnGSettings) btnGSettings.classList.add('hidden');

			statusEl.textContent = 'Conectando...';
			const connected = await p2p.connectToPeer(id);
			statusEl.textContent = connected ? 'Conexión Segura' : 'Offline';
			statusDot.className = `status-dot ${connected ? 'online' : 'offline'}`;
			
			await updateContactUI(id);
		}
		
		const input = document.getElementById('chat-input') as HTMLInputElement;
		input.value = ''; input.focus();

		// Refrescar lista de contactos para actualizar el estado online en el sidebar
		loadContacts();

		await loadChatHistory(currentChatId);
		
		// Proactivamente intentar re-enviar mensajes pendientes al abrir este chat
		if (type === 'direct') {
			retryPendingMessages(await p2p.hashPubKey(id));
		} else {
			retryPendingMessages();
		}
	}

	// Resto de utilidades
	async function loadChatHistory(chatId: string) {
		const container = document.getElementById('messages-list')!;
		container.innerHTML = '<div class="loading-state">Cargando...</div>';
		const chat = await chatRepo.getChat(chatId);
		container.innerHTML = '';
		if (chat) {
			chat.messages.forEach(m => renderMessage(m));
			scrollToBottom();
		}
	}

	function renderMessage(msg: any) {
		const container = document.getElementById('messages-list')!;
		const loading = container.querySelector('.loading-state');
		if (loading) loading.remove();

		const isMine = msg.senderPubKey === myIdentity.publicKey;
		const isGroup = currentChatType === 'group';
		const isSystem = msg.type === 'system';

		const div = document.createElement('div');
		div.setAttribute('data-id', msg.id);
		div.setAttribute('data-timestamp', msg.timestamp.toString());

		if (isSystem) {
			div.className = 'system-message';
			let systemText = msg.content;
			try {
				const data = JSON.parse(msg.content);
				const sender = msg.senderPubKey === myIdentity.publicKey ? 'Tú' : `@${msg.senderUsername}`;

				if (msg.systemAction === 'group_created') systemText = `🏗️ ${sender} creó el grupo "${data.name}"`;
				else if (msg.systemAction === 'group_renamed') systemText = `✏️ ${sender} renombró el grupo a "${data.newName}"`;
				else if (msg.systemAction === 'member_added') systemText = `➕ ${sender} añadió nuevos participantes`;
				else if (msg.systemAction === 'member_removed') systemText = `🚫 ${sender} expulsó a un participante`;
				else if (msg.systemAction === 'member_left') systemText = `🚪 ${sender} abandonó el grupo`;
			} catch (e) {}

			div.innerHTML = `<span>${systemText}</span>`;
		} else {
			div.className = `message-bubble ${isMine ? 'mine' : 'theirs'}`;
			const statusIcon = isMine ? (msg.status === 'sent' ? '✓' : (msg.status === 'received' ? '✓✓' : '...')) : '';
			div.innerHTML = `
				${isGroup && !isMine ? `<div class="msg-sender">${msg.senderUsername || 'Alguien'}</div>` : ''}
				<div class="msg-content">${msg.content}</div>
				<div class="msg-meta">
					${new Date(msg.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
					<span class="msg-status">${statusIcon}</span>
				</div>
			`;
		}
		container.appendChild(div);
	}
	function updateMessageUIStatus(msgId: string, status: string) {
		const msgEl = document.querySelector(`.message-bubble[data-id="${msgId}"]`);
		if (msgEl) {
			const statusSpan = msgEl.querySelector('.msg-status');
			if (statusSpan) {
				statusSpan.textContent = status === 'sent' ? '✓' : (status === 'received' ? '✓✓' : '...');
			}
		}
	}

	function scrollToBottom() {
		const container = document.getElementById('messages-list')!;
		container.scrollTop = container.scrollHeight;
	}

	document.getElementById('chat-form')?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const input = document.getElementById('chat-input') as HTMLInputElement;
		const text = input.value.trim();
		if (!text || !currentChatId) return;
		
		const isGroup = currentChatType === 'group';
		if (!isGroup && !currentChatPubKey) return;

		input.value = '';
		const timestamp = Date.now();
		const msgId = Math.random().toString(36).substring(7);
		const { ciphertext, iv } = await encryptText(text, currentChatId);
		
		const rawMessage: any = { 
			id: msgId, 
			senderPubKey: myIdentity.publicKey, 
			senderUsername: myIdentity.username,
			content: text, 
			timestamp, 
			status: 'pending', 
			iv 
		};

		if (isGroup) {
			rawMessage.groupId = currentChatId;
		} else {
			rawMessage.receiverPubKey = currentChatPubKey;
		}

		renderMessage(rawMessage);
		scrollToBottom();

		const p2pPayload = { 
			type: 'chat', 
			id: msgId, 
			senderPubKey: myIdentity.publicKey, 
			senderUsername: myIdentity.username,
			content: ciphertext, 
			timestamp, 
			iv,
			groupId: isGroup ? currentChatId : undefined
		};

		if (isGroup) {
			// Broadcast a todos los participantes excepto yo
			const others = currentGroupParticipants.filter(p => p !== myIdentity.publicKey);
			let sentCount = 0;
			await Promise.all(others.map(async (pubKey) => {
				try {
					await p2p.sendP2PMessage(pubKey, p2pPayload);
					sentCount++;
				} catch (err) {
					console.warn(`Could not send message to ${pubKey}`);
				}
			}));
			if (sentCount > 0) {
				rawMessage.status = 'sent';
				updateMessageUIStatus(msgId, 'sent');
			}
		} else {
			try { 
				await p2p.sendP2PMessage(currentChatPubKey!, p2pPayload); 
				rawMessage.status = 'sent'; 
				updateMessageUIStatus(msgId, 'sent');
			} catch (err) { 
				console.warn("Peer offline."); 
			}
		}
		
		await chatRepo.addMessage(currentChatId, rawMessage);
		loadContacts(); // Refrescar para mover al principio
	});
document.getElementById('btn-hero-new-chat')?.addEventListener('click', () => {
	globalSearch?.focus();
});

// Logout
document.getElementById('btn-logout')?.addEventListener('click', () => {
	bitid.lock();
	window.location.reload();
});

async function getChatId(pub1: string, pub2: string) {
	const combined = [pub1, pub2].sort().join('-');
	const msgUint8 = new TextEncoder().encode(combined);
	const hashBuffer = await crypto.subtle.digest('SHA-256', msgUint8);
	const hashArray = Array.from(new Uint8Array(hashBuffer));
	return hashArray.map(b => b.toString(16).padStart(2, '0')).join('').substring(0, 16);
}

initApp();
</script>
