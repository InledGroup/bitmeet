	// 3.1 REINTENTO DE MENSAJES PENDIENTES
	async function retryPendingMessages(targetPubKey?: string) {
		const chats = await chatRepo.listAllChats();
		for (const chat of chats) {
			const pendingMsgs = chat.messages.filter(m => m.status === 'pending');
			if (pendingMsgs.length === 0) continue;

			if (chat.type === 'direct') {
				const otherPubKey = chat.participants.find(p => p !== myIdentity.publicKey);
				if (!otherPubKey) continue;

				if (targetPubKey && targetPubKey !== otherPubKey) continue;

				const isConnected = await p2p.isConnected(otherPubKey);
				const isOnline = isConnected || (await p2p.getPresence(otherPubKey)) === 'online';
				
				// Si no está conectado pero sabemos que está online, intentamos forzar conexión
				if (!isConnected && isOnline) {
					console.log(`Peer ${otherPubKey} online pero no conectado. Intentando conectar...`);
					await p2p.connectToPeer(otherPubKey);
				}

				if (!isConnected && !isOnline && !targetPubKey) continue;

				console.log(`Re-enviando ${pendingMsgs.length} mensajes a ${otherPubKey}...`);
				for (const msg of pendingMsgs) {
					try {
						const { ciphertext, iv } = await encryptText(msg.content, chat.id);
						const p2pPayload = { 
							type: 'chat', 
							id: msg.id, 
							senderPubKey: myIdentity.publicKey, 
							senderUsername: myIdentity.username,
							content: ciphertext, 
							timestamp: msg.timestamp, 
							iv,
							groupId: undefined
						};
						await p2p.sendP2PMessage(otherPubKey, p2pPayload);
						await chatRepo.updateMessageStatus(chat.id, msg.id, 'sent');
						if (currentChatId === chat.id) updateMessageUIStatus(msg.id, 'sent');
						console.log(`Mensaje ${msg.id} ("${msg.content.substring(0,10)}...") re-enviado con éxito.`);
					} catch (e) {
						console.warn(`Error al re-enviar mensaje ${msg.id} a ${otherPubKey}:`, e);
						// No hacemos break, intentamos el siguiente por si acaso
					}
				}
			} else {
				// Para grupos, intentamos re-enviar si algún participante está conectado
				const others = chat.participants.filter(p => p !== myIdentity.publicKey);
				for (const msg of pendingMsgs) {
					let sentAtLeastToOne = false;
					const { ciphertext, iv } = await encryptText(msg.content, chat.id);
					const p2pPayload = { 
						type: 'chat', 
						id: msg.id, 
						senderPubKey: myIdentity.publicKey, 
						senderUsername: myIdentity.username,
						content: ciphertext, 
						timestamp: msg.timestamp, 
						iv,
						groupId: chat.id
					};

					for (const pubKey of others) {
						try {
							if (targetPubKey && targetPubKey !== pubKey) continue;

							// Intentar conectar si está online
							const isConnected = await p2p.isConnected(pubKey);
							if (!isConnected && (await p2p.getPresence(pubKey)) === 'online') {
								await p2p.connectToPeer(pubKey);
							}

							if (await p2p.isConnected(pubKey)) {
								await p2p.sendP2PMessage(pubKey, p2pPayload);
								sentAtLeastToOne = true;
							}
						} catch (err) {}
					}

					if (sentAtLeastToOne) {
						await chatRepo.updateMessageStatus(chat.id, msg.id, 'sent');
						if (currentChatId === chat.id) updateMessageUIStatus(msg.id, 'sent');
					}
				}
			}
		}
	}

	async function syncChat(chatId: string, otherPubKey: string) {
		const chat = await chatRepo.getChat(chatId);
		if (!chat) return;
		
		const receivedMsgs = chat.messages.filter(m => m.senderPubKey === otherPubKey);
		const lastReceivedTs = receivedMsgs.length > 0 ? Math.max(...receivedMsgs.map(m => m.timestamp)) : 0;
		
		console.log(`Enviando sync-ping a ${otherPubKey} para chat ${chatId}. Último recibido: ${new Date(lastReceivedTs).toLocaleTimeString()}`);
		
		try {
			await p2p.sendP2PMessage(otherPubKey, {
				type: 'sync-ping',
				chatId: chatId,
				lastReceivedTimestamp: lastReceivedTs,
				senderPubKey: myIdentity.publicKey
			});
		} catch (e) {
			console.warn("Error enviando sync-ping", e);
		}
	}

	// 3. P2P Y NOTIFICACIONES DE LLAMADA
	async function startP2P() {
		await p2p.initialize(myIdentity.publicKey);
		document.querySelector('.status-circle')?.classList.replace('offline', 'online');
		await loadContacts();

		// RE-ACTIVAR SEEDING DE ÚLTIMAS 24H
		try {
			const recentFiles = await chatRepo.listRecentFiles(24 * 60 * 60 * 1000);
			if (recentFiles.length > 0) {
				console.log(`[BitMeet] Re-seedizando ${recentFiles.length} archivos...`);
				if (!torrentClient) torrentClient = await getWebTorrentClient();
				for (const f of recentFiles) {
					let magnetURI = f.magnetURI;
					
					// Fallback: si no tiene magnetURI guardado directamente, lo buscamos en los chats (compatibilidad con archivos guardados antes del cambio)
					if (!magnetURI) {
						const chats = await chatRepo.listAllChats();
						for(const c of chats) {
							const msg = c.messages.find(m => m.id === f.msgId);
							if (msg && msg.type === 'file') {
								try {
									magnetURI = JSON.parse(msg.content).magnetURI;
								} catch(e) {}
								break;
							}
						}
					}
					
					if (magnetURI && !torrentClient.get(magnetURI)) {
						const blob = new Blob([f.data], { type: 'application/octet-stream' });
						torrentClient.seed(blob, { announce: TRACKERS }, (t: any) => {
							console.log(`[BitMeet] Re-seeding: ${t.infoHash}`);
						});
					}
				}
			}
		} catch (e) {
			console.error("[BitMeet] Error in auto-seeding", e);
		}
		
		p2p.onPeerConnected(async (pubKey: string) => {
			console.log(`Peer conectado: ${pubKey}, sincronizando...`);
			
			// 1. Reintentar mensajes que nosotros tenemos como pendientes
			retryPendingMessages(pubKey);
			
			// 2. Pedir mensajes que el otro pueda tener y nosotros no
			const chatId = await getChatId(myIdentity.publicKey, pubKey);
			syncChat(chatId, pubKey);
		});

		retryPendingMessages(); // Reintentar al conectar inicial

		p2p.onMessageReceived(async (msg: any) => {
			if (msg.type === 'sync-ping') {
				console.log(`Recibido sync-ping de ${msg.senderPubKey} para chat ${msg.chatId}. Pide msgs > ${msg.lastReceivedTimestamp}`);
				const chat = await chatRepo.getChat(msg.chatId);
				if (!chat) return;
				
				const missingMsgs = chat.messages.filter(m => 
					m.senderPubKey === myIdentity.publicKey && 
					m.timestamp > msg.lastReceivedTimestamp
				);
				
				if (missingMsgs.length > 0) {
					console.log(`Enviando ${missingMsgs.length} mensajes perdidos a ${msg.senderPubKey}...`);
					for (const m of missingMsgs) {
						const { ciphertext, iv } = await encryptText(m.content, chat.id);
						await p2p.sendP2PMessage(msg.senderPubKey, { 
							type: 'chat', 
							id: m.id, 
							senderPubKey: myIdentity.publicKey, 
							senderUsername: myIdentity.username,
							content: ciphertext, 
							timestamp: m.timestamp, 
							iv,
							groupId: m.groupId
						});
					}
				}
				return;
			}

			if (msg.type === 'calendar-invite') {
				await calendarRepo.saveInvitation({
					id: msg.id,
					eventId: msg.eventId,
					organizerPubKey: msg.organizerPubKey,
					organizerUsername: msg.organizerUsername,
					title: msg.title,
					description: msg.description,
					startTime: msg.startTime,
					endTime: msg.endTime,
					meetingLink: msg.meetingLink,
					isNative: msg.isNative,
					status: 'pending',
					receivedAt: Date.now()
				});
				if (notificationsEnabled) {
					new Notification("Nueva invitación a reunión", { body: `${msg.organizerUsername} te ha invitado a "${msg.title}"`, icon: "/favicon.svg" });
				}
				if (!viewCalls?.classList.contains('hidden')) loadCallsView();
				return;
			}

			if (msg.type === 'calendar-response') {
				const event = await calendarRepo.getEvent(msg.eventId);
				if (event) {
					// En una implementación real, podríamos guardar quién aceptó. 
					// Por ahora, notificamos al organizador.
					if (notificationsEnabled) {
						new Notification("Respuesta a reunión", { body: `${msg.responderUsername} ha ${msg.status === 'accepted' ? 'aceptado' : 'rechazado'} la reunión "${event.title}"`, icon: "/favicon.svg" });
					}
				}
				return;
			}

			if (msg.type === 'calendar-cancel') {
				await calendarRepo.deleteEvent(msg.eventId);
				// Si la vista de calendario está activa, refrescarla
				if (!viewCalendar?.classList.contains('hidden')) {
					renderCalendar();
				}
				return;
			}

			if (msg.type === 'chat' || msg.type === 'system') {
				const isGroup = !!msg.groupId;
				const chatId = isGroup ? msg.groupId : await getChatId(msg.senderPubKey, myIdentity.publicKey);
				
				// Verificar bloqueo
				const contact = await chatRepo.getContact(msg.senderPubKey);
				if (contact?.isBlocked) return;

				let text = msg.content;
				let decryptedData = null;

				try { 
					text = await decryptText(msg.content, msg.iv, chatId); 
					if (msg.type === 'system') {
						decryptedData = JSON.parse(text);
					}
				} catch (e) { 
					text = "🔒 Error de cifrado"; 
				}

				const message = {
					id: msg.id, 
					senderPubKey: msg.senderPubKey, 
					senderUsername: msg.senderUsername,
					receiverPubKey: isGroup ? undefined : myIdentity.publicKey,
					groupId: isGroup ? msg.groupId : undefined,
					content: text, 
					timestamp: msg.timestamp, 
					type: msg.msgType || (msg.type === 'system' ? 'system' : 'text'),
					systemAction: msg.systemAction,
					status: 'received', 
					iv: msg.iv
				};

				// Si me han expulsado o me he ido, y recibo un mensaje de ese grupo, lo ignoro si ya no estoy
				if (isGroup && (msg.systemAction === 'member_removed' || msg.systemAction === 'member_left')) {
					if (decryptedData && !decryptedData.participants.includes(myIdentity.publicKey)) {
						// He sido expulsado o ya me fui (mensaje duplicado o tardío). Podríamos borrar el chat.
						const db = (chatRepo as any).db;
						if (db) {
							const tx = db.transaction("chats", "readwrite");
							tx.objectStore("chats").delete(chatId);
						}
						if (currentChatId === chatId) {
							viewActiveChat?.classList.add('hidden');
							viewNoChat?.classList.remove('hidden');
						}
						loadContacts();
						return;
					}
				}

				await chatRepo.addMessage(chatId, message as any);
				
				if (currentChatId === chatId) { 
					if (msg.type === 'system') {
						// Actualizar UI en tiempo real si el chat está abierto
						if (msg.systemAction === 'group_renamed' && decryptedData?.newName) {
							document.getElementById('active-chat-name')!.textContent = decryptedData.newName;
						} else if (decryptedData?.participants) {
							currentGroupParticipants = decryptedData.participants;
							const statusEl = document.getElementById('active-chat-status')!;
							statusEl.textContent = `${currentGroupParticipants.length} participantes`;
							// Si el modal está abierto, refrescar lista de miembros
							if (!groupSettingsModal?.classList.contains('hidden')) {
								const isOwner = currentGroupOwner === myIdentity.publicKey;
								renderGroupParticipants(currentGroupParticipants, isOwner);
							}
						}
					}
					
					const lastMsgEl = document.querySelector('#messages-list .message-bubble:last-child') as HTMLElement;
					const lastTs = lastMsgEl ? parseInt(lastMsgEl.getAttribute('data-timestamp') || '0') : 0;

					if (message.timestamp < lastTs) {
						await loadChatHistory(chatId);
					} else {
						renderMessage(message as any); 
						scrollToBottom(); 
					}

					if (!isGroup && !isGroup) {
						// Actualizar nombre si era desconocido
						const nameEl = document.getElementById('active-chat-name');
						if (nameEl && nameEl.textContent?.includes('Desconocido') && msg.senderUsername) {
							nameEl.textContent = msg.senderUsername;
							await chatRepo.saveContact({
								publicKey: msg.senderPubKey,
								username: msg.senderUsername,
								isFavorite: false
							});
							const sidebarItem = document.querySelector(`[data-pubkey="${msg.senderPubKey}"] strong`) || document.querySelector(`[data-id="${msg.senderPubKey}"] strong`);
							if (sidebarItem) sidebarItem.textContent = msg.senderUsername;
						}
					}
				} else {
					await loadContacts();
					const selector = isGroup ? `[data-id="${msg.groupId}"]` : `[data-pubkey="${msg.senderPubKey}"]`;
					const item = document.querySelector(selector);
					if (item) item.classList.add('unread');
				}

				// Notificaciones
				if (notificationsEnabled && msg.type !== 'system') {
					messageSound?.play().catch(e => console.warn("Error playing sound", e));
					if (document.hidden && "Notification" in window && Notification.permission === "granted") {
						const title = isGroup ? `Mensaje en grupo` : `Mensaje de @${msg.senderUsername}`;
						const notification = new Notification(title, { body: text, icon: "/favicon.svg" });
						notification.onclick = () => {
							window.focus();
							chatRepo.getChat(chatId).then(chat => {
								selectChat(chatId, chat?.name || (isGroup ? "Grupo" : msg.senderUsername), isGroup ? 'group' : 'direct');
							});
						};
					}
				}
			} else if (msg.type === 'call-invite') {
				document.getElementById('incoming-caller-name')!.textContent = msg.callerName || "Llamada entrante";
				incomingPopup?.classList.remove('hidden');
				ringtone?.play();
				pendingCallPubKey = msg.senderPubKey;

				// GUARDAR INVITED PEERS PARA EL OVERLAY
				(window as any).pendingInvitedPeers = msg.invitedPeers;

				// Importante: Guardamos el PeerID del emisor que viene en el mensaje P2P
				if (msg.peerId) {
					console.log("[BitMeet] Call invite received with PeerID:", msg.peerId);
					(window as any).pendingCallerPeerId = msg.peerId;
				}

				if (Notification.permission === "granted") {
					new Notification("BitSuite Teams", { body: `Llamada entrante de @${msg.callerName}`, icon: "/favicon.svg" });
				}
			} else if (msg.type === 'call-accept') {
				console.log("[BitMeet] El receptor ha aceptado la llamada con PeerID:", msg.peerId);
				window.dispatchEvent(new CustomEvent('bitmeet:call-accepted', { detail: msg }));
			} else if (msg.type === 'call-reject') {
				import('../lib/callStore').then(store => {
					store.endCall();
				});
				alert(`@${msg.senderUsername} ha rechazado la llamada.`);
			}
		});

		p2p.onIncomingCall(async (call: any) => {
			console.log("[BitMeet] PeerJS Call incoming from:", call.peer);
			pendingCall = call;
			
			// Si ya habíamos aceptado por el mensaje de chat P2P, contestamos YA
			if (userAcceptedPending && pendingCallPubKey) {
				console.log("[BitMeet] Auto-answering call because user already clicked accept");
				incomingPopup?.classList.add('hidden');
				ringtone?.pause();
				ringtone!.currentTime = 0;
				const roomId = await getChatId(myIdentity.publicKey, pendingCallPubKey);
