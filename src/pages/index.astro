---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Teams/Sidebar.astro';
import ListPanel from '../components/Teams/ListPanel.astro';
import ChatArea from '../components/Teams/ChatArea.astro';
import CallWrapper from '../components/Teams/CallWrapper';
import AuthModal from '../components/Teams/AuthModal.astro';
import TeamsSettingsModal from '../components/Teams/TeamsSettingsModal.astro';
import GroupModal from '../components/Teams/GroupModal.astro';
import GroupSettingsModal from '../components/Teams/GroupSettingsModal.astro';
import CallOverlay from '../components/Teams/CallOverlay';
import '../styles/global.css';
---

<Layout title="BitSuite Teams">
	<main id="teams-app" class="apple-container">
		<Sidebar />
		<ListPanel />
		<ChatArea />
		<AuthModal />
		<TeamsSettingsModal />
		<GroupModal />
		<GroupSettingsModal />
		

		<!-- 6. POPUP DE LLAMADA ENTRANTE -->
		<div id="incoming-call-popup" class="incoming-call-popup hidden">
			<div class="incoming-info">
				<div class="incoming-avatar" id="incoming-caller-avatar">?</div>
				<div class="incoming-text">
					<strong id="incoming-caller-name">Usuario</strong>
					<span>Llamada entrante...</span>
				</div>
			</div>
			<div class="incoming-actions">
				<button class="incoming-btn accept" id="btn-accept-call">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
				</button>
				<button class="incoming-btn decline" id="btn-reject-call">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
				</button>
			</div>
		</div>
	</main>
	<CallWrapper client:only="react" />
</Layout>

<style>
	.apple-container {
		display: flex;
		height: 100vh;
		width: 100vw;
		background: var(--apple-bg);
		overflow: hidden;
		color: var(--apple-text);
		user-select: none;
	}

	/* Incoming Call Popup */
	.incoming-call-popup {
		position: fixed;
		top: 24px;
		right: 24px;
		background: rgba(255, 255, 255, 0.8);
		backdrop-filter: blur(30px) saturate(180%);
		border: 1px solid var(--apple-border);
		border-radius: 20px;
		padding: 16px;
		width: 320px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		box-shadow: 0 10px 40px rgba(0,0,0,0.1);
		z-index: 4000;
		animation: slideInRight 0.5s cubic-bezier(0.25, 0.1, 0.25, 1);
	}
	@keyframes slideInRight { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }

	.incoming-info { display: flex; align-items: center; gap: 12px; }
	.incoming-avatar {
		width: 44px;
		height: 44px;
		background: var(--apple-accent);
		color: white;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 600;
		font-size: 18px;
	}
	.incoming-text { display: flex; flex-direction: column; }
	.incoming-text strong { font-size: 15px; }
	.incoming-text span { font-size: 13px; color: var(--apple-text-secondary); }

	.incoming-actions { display: flex; gap: 10px; }
	.incoming-btn {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		border: none;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
		transition: transform 0.2s;
	}
	.incoming-btn:hover { transform: scale(1.1); }
	.incoming-btn.accept { background: #34C759; }
	.incoming-btn.decline { background: #FF3B30; }
</style>

<script>
	import { BitIDService } from '../lib/bitid';
	import { P2PTransport } from '../infrastructure/adapters/P2PTransport';
	import { IndexedDBChatRepository } from '../infrastructure/adapters/IndexedDBChatRepository';
	import { encryptText, decryptText } from '../lib/crypto';
	import { startCall, receiveCall } from '../lib/callStore';
	
	// Estado global
	const bitid = new BitIDService();
	const p2p = new P2PTransport();
	const chatRepo = new IndexedDBChatRepository();
	let myIdentity: any = null;
	let currentChatPubKey: string | null = null;
	let currentChatId: string | null = null;
	let ringtone: HTMLAudioElement | null = null;
	let messageSound: HTMLAudioElement | null = null;
	let pendingCall: any = null;
	let pendingCallPubKey: string | null = null;
	let userAcceptedPending = false;
	let notificationsEnabled = localStorage.getItem('teams-notifications') !== 'false';
	
	// Elementos UI
	const teamsApp = document.getElementById('teams-app');
	const authOverlay = document.getElementById('auth-overlay');
	const authCard = document.getElementById('auth-card');
	const authUnlockView = document.getElementById('auth-unlock-view');
	const authImportView = document.getElementById('auth-import-view');
	const passwordInput = document.getElementById('master-password') as HTMLInputElement;
	const viewNoChat = document.getElementById('view-no-chat');
	const viewActiveChat = document.getElementById('view-active-chat');
	const chatsList = document.getElementById('chats-list');
	const searchResults = document.getElementById('search-results');
	const globalSearch = document.getElementById('global-search') as HTMLInputElement;
	const btnToggleContact = document.getElementById('btn-toggle-contact');
	const incomingPopup = document.getElementById('incoming-call-popup');
	const unknownActions = document.getElementById('unknown-user-actions');
	const btnSaveContact = document.getElementById('btn-save-contact');
	const btnBlockUser = document.getElementById('btn-block-user');
	const btnUnlockApp = document.getElementById('btn-unlock-app');
	const btnTriggerImport = document.getElementById('btn-trigger-import');
	const importFile = document.getElementById('import-file') as HTMLInputElement;

	const btnNewGroup = document.getElementById('btn-new-group');
	const groupModal = document.getElementById('group-modal-overlay');
	const btnCancelGroup = document.getElementById('btn-cancel-group');
	const btnCreateGroup = document.getElementById('btn-create-group');
	const groupNameInput = document.getElementById('group-name') as HTMLInputElement;
	const groupParticipantsList = document.getElementById('group-participants-list');

	const btnGroupSettings = document.getElementById('btn-group-settings');
	const groupSettingsModal = document.getElementById('group-settings-overlay');
	const btnCloseGroupSettings = document.getElementById('btn-close-group-settings');
	const editGroupNameInput = document.getElementById('edit-group-name') as HTMLInputElement;
	const btnSaveGroupName = document.getElementById('btn-save-group-name');
	const currentGroupParticipantsEl = document.getElementById('current-group-participants');
	const addMoreParticipantsEl = document.getElementById('add-more-participants-list');
	const btnAddMembers = document.getElementById('btn-add-selected-members');
	const btnLeaveGroup = document.getElementById('btn-leave-group');
	
	const settingsOverlay = document.getElementById('teams-settings-overlay');
	const btnOpenSettings = document.getElementById('btn-open-settings');
	const btnCloseSettings = document.getElementById('btn-close-settings');
	const checkNotifications = document.getElementById('check-notifications') as HTMLInputElement;

	let currentChatType: 'direct' | 'group' = 'direct';
	let currentGroupParticipants: string[] = [];
	let currentGroupOwner: string | null = null;

	// Iniciar
	async function initApp() {
		console.log("[BitMeet] Starting initApp...");
		authOverlay?.classList.remove('hidden');
		authUnlockView?.classList.add('hidden');
		authImportView?.classList.add('hidden');
		
		// 1. Splash Screen de 3 segundos
		console.log("[BitMeet] Waiting for splash...");
		await new Promise(resolve => setTimeout(resolve, 3000));

		try {
			console.log("[BitMeet] Checking identity...");
			const id = await bitid.getIdentity();
			console.log("[BitMeet] Identity result:", id);
			
			// Inicializar sonidos
			ringtone = new Audio('/notify.mp3'); 
			ringtone.loop = true;
			messageSound = new Audio('/notify.mp3');

			if (!id) {
				console.log("[BitMeet] No identity found, showing import view.");
				authImportView?.classList.remove('hidden');
			} else {
				console.log("[BitMeet] Identity found, trying auto-unlock...");
				const autoKey = await bitid.autoUnlock();
				console.log("[BitMeet] Auto-unlock result:", autoKey ? "Success" : "Failed/No session");
				
				if (autoKey) {
					myIdentity = id;
					authOverlay?.classList.add('hidden');
					teamsApp?.classList.remove('hidden');
					const welcomeName = document.getElementById('welcome-name');
					if (welcomeName) welcomeName.textContent = id.username;
					console.log("[BitMeet] Starting P2P...");
					await startP2P();
					console.log("[BitMeet] P2P Started.");
				} else {
					console.log("[BitMeet] Auto-unlock failed or no session, showing unlock view.");
					authUnlockView?.classList.remove('hidden');
				}
			}
		} catch (err) {
			console.error("[BitMeet] Critical error during initApp:", err);
			// Si hay un error crítico, al menos intentamos mostrar algo al usuario
			authImportView?.classList.remove('hidden');
			alert("Error al cargar la identidad. Por favor, revisa la consola.");
		}

		// Solicitar permisos notificaciones
		if ("Notification" in window && Notification.permission === "default") {
			Notification.requestPermission();
		}

		if (checkNotifications) {
			checkNotifications.checked = notificationsEnabled;
			checkNotifications.addEventListener('change', (e) => {
				notificationsEnabled = (e.target as HTMLInputElement).checked;
				localStorage.setItem('teams-notifications', String(notificationsEnabled));
			});
		}

		btnOpenSettings?.addEventListener('click', () => settingsOverlay?.classList.remove('hidden'));
		btnCloseSettings?.addEventListener('click', () => settingsOverlay?.classList.add('hidden'));
	}

	// 0. AUTH EVENT LISTENERS
	btnUnlockApp?.addEventListener('click', async () => {
		const pass = passwordInput.value;
		if (!pass) return;
		const key = await bitid.unlock(pass);
		if (key) {
			const id = await bitid.getIdentity();
			myIdentity = id;
			
			// Animación de éxito Apple ID
			authCard?.classList.add('unlock-success');
			setTimeout(async () => {
				authOverlay?.classList.add('hidden');
				teamsApp?.classList.remove('hidden');
				const welcomeName = document.getElementById('welcome-name');
				if (welcomeName) welcomeName.textContent = id!.username;
				await startP2P();
			}, 600);
		} else {
			alert("Contraseña incorrecta");
		}
	});

	passwordInput?.addEventListener('keydown', (e) => {
		if (e.key === 'Enter') btnUnlockApp?.click();
	});

	btnTriggerImport?.addEventListener('click', () => {
		importFile.click();
	});

	// 0.1 GROUP MODAL EVENT LISTENERS
	btnNewGroup?.addEventListener('click', async () => {
		const savedContacts = await chatRepo.listContacts();
		const colleagues = await bitid.getColleagues();
		const all: any[] = [...savedContacts.filter(c => !c.isBlocked)];
		colleagues.forEach(c => {
			if (!all.find(a => a.publicKey === c.public_key)) {
				all.push({ publicKey: c.public_key, username: c.username });
			}
		});

		if (groupParticipantsList) {
			groupParticipantsList.innerHTML = all.map(c => `
				<div class="participant-item">
					<input type="checkbox" id="p-${c.publicKey}" value="${c.publicKey}" data-username="${c.username}" class="group-p-checkbox" />
					<label for="p-${c.publicKey}">${c.username}</label>
				</div>
			`).join('');
		}
		
		groupNameInput.value = '';
		groupModal?.classList.remove('hidden');
	});

	btnGroupSettings?.addEventListener('click', async () => {
		console.log("[BitMeet] Click en ajustes de grupo. Tipo:", currentChatType, "ID:", currentChatId);
		if (currentChatType !== 'group' || !currentChatId) return;
		
		const chat = await chatRepo.getChat(currentChatId);
		if (!chat) {
			console.error("[BitMeet] No se encontró el chat en el repo para ID:", currentChatId);
			return;
		}
		
		editGroupNameInput.value = chat.name || '';
		currentGroupOwner = chat.owner || null;
		
		// Solo owner puede renombrar o añadir/echar
		const isOwner = currentGroupOwner === myIdentity.publicKey;
		console.log("[BitMeet] Abriendo modal de ajustes. ¿Es owner?:", isOwner);

		const renameSection = document.getElementById('group-rename-section');
		const addSection = document.getElementById('add-more-section');
		const subtitle = document.getElementById('group-settings-subtitle');
		
		if (renameSection) renameSection.classList.toggle('hidden', !isOwner);
		if (addSection) addSection.classList.toggle('hidden', !isOwner);
		if (subtitle) subtitle.textContent = isOwner ? "Gestiona los participantes y el nombre." : "Lista de participantes";
		
		await renderGroupParticipants(chat.participants, isOwner);
		if (isOwner) {
			await renderAddMoreParticipants(chat.participants);
		} else {
			if (addMoreParticipantsEl) addMoreParticipantsEl.innerHTML = '';
		}
		
		groupSettingsModal?.classList.remove('hidden');
	});

	async function renderGroupParticipants(participants: string[], isOwner: boolean) {
		if (!currentGroupParticipantsEl) return;
		
		const list = await Promise.all(participants.map(async p => {
			const contact = await chatRepo.getContact(p);
			const name = p === myIdentity.publicKey ? 'Tú' : (contact?.username || `Desconocido (${p.substring(0,6)})`);
			const canKick = isOwner && p !== myIdentity.publicKey;
			
			return `
				<div class="member-item">
					<span class="member-name">${name} ${p === currentGroupOwner ? '👑' : ''}</span>
					${canKick ? `<button class="btn-kick" data-pubkey="${p}">Expulsar</button>` : ''}
				</div>
			`;
		}));
		
		currentGroupParticipantsEl.innerHTML = list.join('');
		
		currentGroupParticipantsEl.querySelectorAll('.btn-kick').forEach(btn => {
			btn.addEventListener('click', async (e) => {
				const pubKey = (e.currentTarget as HTMLElement).getAttribute('data-pubkey');
				if (pubKey) await removeMember(pubKey);
			});
		});
	}

	async function renderAddMoreParticipants(currentParticipants: string[]) {
		if (!addMoreParticipantsEl) return;
		
		const contacts = await chatRepo.listContacts();
		const colleagues = await bitid.getColleagues();
		const all = [...contacts.filter(c => !c.isBlocked)];
		colleagues.forEach(c => {
			if (!all.find(a => a.publicKey === c.public_key)) all.push({ publicKey: c.public_key, username: c.username });
		});
		
		const available = all.filter(c => !currentParticipants.includes(c.publicKey));
		
		addMoreParticipantsEl.innerHTML = available.map(c => `
			<div class="participant-item">
				<input type="checkbox" id="add-${c.publicKey}" value="${c.publicKey}" class="add-member-checkbox" />
				<label for="add-${c.publicKey}">${c.username}</label>
			</div>
		`).join('');
		
		if (available.length === 0) addMoreParticipantsEl.innerHTML = '<div class="empty-results">No hay más contactos</div>';
	}

	btnCloseGroupSettings?.addEventListener('click', () => {
		groupSettingsModal?.classList.add('hidden');
	});

	btnSaveGroupName?.addEventListener('click', async () => {
		const newName = editGroupNameInput.value.trim();
		if (!newName || !currentChatId) return;
		
		await broadcastSystemMessage('group_renamed', { newName });
		await chatRepo.updateGroupMetadata(currentChatId, { name: newName });
		document.getElementById('active-chat-name')!.textContent = newName;
		await loadContacts();
		alert("Nombre actualizado");
	});

	btnAddMembers?.addEventListener('click', async () => {
		const selected = Array.from(document.querySelectorAll('.add-member-checkbox:checked')) as HTMLInputElement[];
		if (selected.length === 0 || !currentChatId) return;
		
		const newKeys = selected.map(s => s.value);
		const chat = await chatRepo.getChat(currentChatId);
		if (!chat) return;
		
		const updatedParticipants = [...chat.participants, ...newKeys];
		await broadcastSystemMessage('member_added', { 
			participants: updatedParticipants,
			name: chat.name,
			owner: chat.owner
		}, updatedParticipants); // Mandar a todos los nuevos también
		
		await chatRepo.updateGroupMetadata(currentChatId, { participants: updatedParticipants });
		await renderGroupParticipants(updatedParticipants, true);
		await renderAddMoreParticipants(updatedParticipants);
		loadContacts();
	});

	async function removeMember(pubKey: string) {
		if (!currentChatId || !confirm("¿Expulsar a este participante?")) return;
		
		const chat = await chatRepo.getChat(currentChatId);
		if (!chat) return;
		
		const updatedParticipants = chat.participants.filter(p => p !== pubKey);
		
		// Notificar al expulsado y a los demás
		await broadcastSystemMessage('member_removed', { participants: updatedParticipants }, chat.participants);
		
		await chatRepo.updateGroupMetadata(currentChatId, { participants: updatedParticipants });
		await renderGroupParticipants(updatedParticipants, true);
		await renderAddMoreParticipants(updatedParticipants);
		loadContacts();
	}

	btnLeaveGroup?.addEventListener('click', async () => {
		if (!currentChatId || !confirm("¿Seguro que quieres irte del grupo?")) return;
		
		const chat = await chatRepo.getChat(currentChatId);
		if (!chat) return;
		
		const updatedParticipants = chat.participants.filter(p => p !== myIdentity.publicKey);
		
		// Si soy el owner, el grupo se queda sin owner o podríamos pasar el testigo. 
		// Por simplicidad, notificamos que nos vamos.
		await broadcastSystemMessage('member_left', { participants: updatedParticipants });
		
		// Borrar el chat localmente o marcarlo como abandonado
		// Por ahora lo borramos para salir de la vista
		const db = (chatRepo as any).db;
		const tx = db.transaction("chats", "readwrite");
		tx.objectStore("chats").delete(currentChatId);
		
		groupSettingsModal?.classList.add('hidden');
		viewActiveChat?.classList.add('hidden');
		viewNoChat?.classList.remove('hidden');
		loadContacts();
	});

	async function broadcastSystemMessage(action: string, data: any, customParticipants?: string[]) {
		if (!currentChatId) return;
		
		const { ciphertext, iv } = await encryptText(JSON.stringify(data), currentChatId);
		const msgId = Math.random().toString(36).substring(7);
		
		const systemMsg: any = {
			id: msgId,
			senderPubKey: myIdentity.publicKey,
			senderUsername: myIdentity.username,
			groupId: currentChatId,
			content: ciphertext,
			timestamp: Date.now(),
			type: 'system',
			systemAction: action,
			status: 'sent',
			iv
		};
		
		const participants = customParticipants || currentGroupParticipants;
		const others = participants.filter(p => p !== myIdentity.publicKey);
		
		await Promise.all(others.map(async p => {
			try { await p2p.sendP2PMessage(p, systemMsg); } catch(e) {}
		}));
		
		await chatRepo.addMessage(currentChatId, { ...systemMsg, content: JSON.stringify(data) } as any);
	}

	btnCancelGroup?.addEventListener('click', () => {
		groupModal?.classList.add('hidden');
	});

	btnCreateGroup?.addEventListener('click', async () => {
		const name = groupNameInput.value.trim();
		if (!name) return alert("Ponle un nombre al grupo");
		
		const selected = Array.from(document.querySelectorAll('.group-p-checkbox:checked')) as HTMLInputElement[];
		if (selected.length === 0) return alert("Selecciona al menos un participante");
		
		const participants = selected.map(s => s.value);
		participants.push(myIdentity.publicKey);
		
		const groupId = 'group-' + Math.random().toString(36).substring(2, 11);
		
		const { ciphertext, iv } = await encryptText(JSON.stringify({
			name,
			participants,
			owner: myIdentity.publicKey
		}), groupId);

		const systemMsg: any = {
			id: Math.random().toString(36).substring(7),
			senderPubKey: myIdentity.publicKey,
			senderUsername: myIdentity.username,
			groupId,
			content: ciphertext,
			timestamp: Date.now(),
			type: 'system',
			systemAction: 'group_created',
			status: 'sent',
			iv
		};
		
		const newGroup: any = {
			id: groupId,
			participants,
			messages: [systemMsg],
			type: "group",
			name,
			owner: myIdentity.publicKey,
			lastUpdate: Date.now()
		};
		
		await chatRepo.saveChat(newGroup);
		groupModal?.classList.add('hidden');
		
		// Broadcast invitación/creación
		const others = participants.filter(p => p !== myIdentity.publicKey);
		others.forEach(pubKey => {
			p2p.sendP2PMessage(pubKey, { ...systemMsg, content: ciphertext }).catch(() => {});
		});

		await loadContacts();
		await selectChat(groupId, name, 'group');
	});

	importFile?.addEventListener('change', (e: any) => {
		const file = e.target.files[0];
		if (!file) return;
		const reader = new FileReader();
		reader.onload = async (ev) => {
			try {
				const data = JSON.parse(ev.target?.result as string);
				await bitid.importIdentity(data);
				window.location.reload();
			} catch (err) {
				alert("Error al importar: formato inválido.");
			}
		};
		reader.readAsText(file);
	});

	// 1. GESTIÓN DE CONTACTOS Y BLOQUEO
	btnToggleContact?.addEventListener('click', async () => {
		await toggleContact();
	});

	btnSaveContact?.addEventListener('click', async () => {
		await toggleContact();
	});

	async function toggleContact() {
		if (!currentChatPubKey || !currentChatId) return;
		let name = document.getElementById('active-chat-name')!.textContent || '';

		// Si el nombre es "Desconocido", intentar encontrar uno mejor en el historial de mensajes
		if (name.includes('Desconocido')) {
			const chat = await chatRepo.getChat(currentChatId);
			if (chat) {
				const lastMsgWithName = [...chat.messages].reverse().find(m => (m as any).senderUsername && m.senderPubKey !== myIdentity.publicKey);
				if (lastMsgWithName) {
					name = (lastMsgWithName as any).senderUsername;
					document.getElementById('active-chat-name')!.textContent = name;
				}
			}
		}

		const existing = await chatRepo.getContact(currentChatPubKey);

		if (existing) {
			await chatRepo.deleteContact(currentChatPubKey);
			btnToggleContact?.classList.remove('active');
		} else {
			await chatRepo.saveContact({
				publicKey: currentChatPubKey,
				username: name,
				isFavorite: true
			});
			btnToggleContact?.classList.add('active');
		}
		await updateContactUI(currentChatPubKey);
		loadContacts();
	}
	btnBlockUser?.addEventListener('click', async () => {
		if (!currentChatPubKey) return;
		if (confirm("¿Estás seguro de que quieres bloquear a este usuario? No volverás a ver sus mensajes.")) {
			await chatRepo.saveContact({
				publicKey: currentChatPubKey,
				username: "Usuario Bloqueado",
				isFavorite: false,
				isBlocked: true
			} as any);
			viewActiveChat?.classList.add('hidden');
			viewNoChat?.classList.remove('hidden');
			loadContacts();
		}
	});

	async function updateContactUI(pubKey: string) {
		const contact = await chatRepo.getContact(pubKey);
		if (contact) {
			btnToggleContact?.classList.add('active');
			unknownActions?.classList.add('hidden');
		} else {
			btnToggleContact?.classList.remove('active');
			unknownActions?.classList.remove('hidden');
		}
	}

	// 2. NAVEGACIÓN Y BÚSQUEDA
	document.querySelectorAll('.sidebar-icon[data-view]').forEach(icon => {
		icon.addEventListener('click', (e) => {
			document.querySelectorAll('.sidebar-icon').forEach(i => i.classList.remove('active'));
			const target = e.currentTarget as HTMLElement;
			target.classList.add('active');
			const view = target.getAttribute('data-view');
			const panelTitle = document.getElementById('panel-title');
			if (panelTitle) panelTitle.textContent = view!.charAt(0).toUpperCase() + view!.slice(1);
			
			if (view === 'chat') {
				loadContacts();
				searchResults?.classList.add('hidden');
				chatsList?.classList.remove('hidden');
			} else if (view === 'teams') {
				loadColleagues(); 
			} else {
				if (chatsList) chatsList.innerHTML = `<div class="loading-state">Próximamente</div>`;
			}
		});
	});

	let searchTimeout: any;
