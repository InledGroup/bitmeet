			const type = (
				document.querySelector(
					'input[name="event-type"]:checked',
				) as HTMLInputElement
			).value as "meeting" | "busy";
			const isNative = (
				document.getElementById("event-is-native") as HTMLInputElement
			).checked;
			const link = (
				document.getElementById("event-link") as HTMLInputElement
			).value;
			const desc = (
				document.getElementById("event-desc") as HTMLTextAreaElement
			).value;

			const eventId = Math.random().toString(36).substring(7);
			const nativeLink = isNative
				? `${window.location.origin}/room/${eventId}`
				: link;

			const event: any = {
				id: eventId,
				title,
				description: desc,
				startTime: start,
				endTime: end,
				type,
				meetingLink: nativeLink,
				isNative,
				organizerPubKey: myIdentity.publicKey,
				participants: selectedParticipants.map((p) => p.pubKey),
				status: "confirmed",
			};

			await calendarRepo.saveEvent(event);

			// Enviar invitaciones P2P con reintento automático
			if (type === "meeting") {
				selectedParticipants.forEach(async (p) => {
					const inviteId = Math.random().toString(36).substring(7);
					const invitePayload = {
						id: inviteId,
						eventId: eventId,
						organizerPubKey: myIdentity.publicKey,
						organizerUsername: myIdentity.username,
						title,
						description: desc,
						startTime: start,
						endTime: end,
						meetingLink: nativeLink,
						isNative,
						timestamp: Date.now(),
					};

					// 1. Guardar en el chat local como 'pending' para reintento automático
					const chatId = await getChatId(
						myIdentity.publicKey,
						p.pubKey,
					);
					await chatRepo.addMessage(chatId, {
						id: inviteId,
						senderPubKey: myIdentity.publicKey,
						senderUsername: myIdentity.username,
						receiverPubKey: p.pubKey,
						content: JSON.stringify(invitePayload),
						timestamp: Date.now(),
						type: "calendar-invite",
						status: "pending",
						iv: "",
					});

					// 2. Intentar envío inmediato
					try {
						await p2p.sendP2PMessage(p.pubKey, {
							type: "calendar-invite",
							...invitePayload,
						});
						await chatRepo.updateMessageStatus(
							chatId,
							inviteId,
							"sent",
						);
						console.log(`Invitación enviada a @${p.username}`);
					} catch (err) {
						console.warn(
							`No se pudo enviar invitación inmediata a @${p.username}. Se reintentará cuando esté online.`,
						);
					}
				});
			}

			eventModal?.classList.add("hidden");
			renderCalendar();
			alert("Evento guardado");
		});

