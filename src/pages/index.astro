							p2p.sendP2PMessage(pub, payload).catch((e) => console.warn("[BitMeet] Error invitando a grupo", e)),
						);
					} else {
						p2p.sendP2PMessage(targetPubKey!, { ...payload, timestamp: Date.now() }).catch((e) => console.error("[BitMeet] Error invitando a contacto", e));
					}
				},
				targetPubKey,
				name,
				allParticipantsMap,
			);
		});

