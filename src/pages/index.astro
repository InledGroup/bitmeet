						const id = (e.currentTarget as HTMLElement).getAttribute('data-id')!;
						await respondToInvitation(id, 'accepted');
					});
				});

				invList.querySelectorAll('.btn-reject-inv').forEach(btn => {
					btn.addEventListener('click', async (e) => {
						const id = (e.currentTarget as HTMLElement).getAttribute('data-id')!;
