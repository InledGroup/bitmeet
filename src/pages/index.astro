	const TRACKERS = [
		"wss://tracker.btorrent.xyz",
		"wss://tracker.openwebtorrent.com",
		"wss://tracker.files.fm:7073/announce",
		"wss://tracker.gbitt.info:443/announce",
	];

	async function downloadFile(msgId: string) {
		const msgEl = document.querySelector(
			`.message-bubble[data-id="${msgId}"]`,
		);
		if (!msgEl) return;

		const btn = msgEl.querySelector(
			".file-download-btn",
		) as HTMLButtonElement;
		if (btn) btn.disabled = true;

		const progressEl = msgEl.querySelector(".file-progress") as HTMLElement;
		if (progressEl) {
			progressEl.classList.remove("hidden");
			progressEl.textContent = "Iniciando...";
		}

		try {
			const chat = await chatRepo.getChat(currentChatId!);
			const msg = chat?.messages.find((m) => m.id === msgId);
			if (!msg || msg.type !== "file") return;

			const fileMeta = JSON.parse(msg.content);
			if (!torrentClient) torrentClient = await getWebTorrentClient();

			const onDone = async (t: any) => {
				if (progressEl) progressEl.textContent = "Descifrando...";
				try {
					const file = t.files[0];
					const encryptedBuf = await file.arrayBuffer();

					// GUARDAR PARA RE-SEEDING FUTURO
					try {
						await chatRepo.saveFileData(
							msgId,
							encryptedBuf,
							fileMeta.magnetURI,
						);
					} catch (e) {}

					const key = await importFileKey(fileMeta.key);
					const iv = new Uint8Array(
						atob(fileMeta.iv)
							.split("")
							.map((c) => c.charCodeAt(0)),
					);

					const decryptedBuf = await decryptFile(
						encryptedBuf,
						key,
						iv,
					);
					const blob = new Blob([decryptedBuf], {
						type: fileMeta.type,
					});
					const url = URL.createObjectURL(blob);
					const a = document.createElement("a");
					a.href = url;
					a.download = fileMeta.name;
					a.click();
					URL.revokeObjectURL(url);

					if (progressEl) {
						progressEl.textContent = "Descargado";
						setTimeout(
							() => progressEl.classList.add("hidden"),
							3000,
						);
					}
				} catch (err) {
					console.error("Decryption error:", err);
					if (progressEl)
						progressEl.textContent = "Error al descifrar";
				} finally {
					if (btn) btn.disabled = false;
				}
			};

			// Búsqueda manual robusta de torrent existente
			let torrent = torrentClient.torrents.find(
				(t: any) =>
					t.magnetURI === fileMeta.magnetURI ||
					t.infoHash === fileMeta.magnetURI ||
					t.infoHash ===
						fileMeta.magnetURI.split("btih:")[1]?.split("&")[0],
			);

			if (torrent && typeof torrent.on === "function") {
				if (torrent.done) onDone(torrent);
				else torrent.on("done", () => onDone(torrent));
			} else {
				try {
					torrent = torrentClient.add(
						fileMeta.magnetURI,
						{ announce: TRACKERS },
						(t: any) => {
							if (t && typeof t.on === "function") {
								t.on("download", () => {
									if (progressEl) {
										const percent = Math.round(
											t.progress * 100,
										);
										progressEl.textContent = `Descargando... ${percent}%`;
									}
								});
								t.on("done", () => onDone(t));
							}
						},
					);
				} catch (e) {
					// Fallback: intentar obtenerlo de nuevo tras el error de duplicado
					const retry = torrentClient.get(fileMeta.magnetURI);
					if (retry && typeof retry.on === "function") onDone(retry);
					else throw e;
				}
			}
		} catch (err) {
			console.error("Download failed:", err);
			if (btn) btn.disabled = false;
			if (progressEl) progressEl.textContent = "Error";
		}
	}
