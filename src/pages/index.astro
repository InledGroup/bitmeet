	async function renderCalendar() {
		const periodEl = document.getElementById('cal-current-period');
		if (periodEl) {
			periodEl.textContent = currentCalendarDate.toLocaleString('es-ES', { month: 'long', year: 'numeric' });
		}

		const grid = document.getElementById('calendar-grid');
		if (!grid) return;
		grid.innerHTML = '';

		// Cabecera días
		const days = ['Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb', 'Dom'];
		days.forEach(d => {
			const cell = document.createElement('div');
			cell.className = 'calendar-day-header';
			cell.textContent = d;
			grid.appendChild(cell);
		});

		const firstDay = new Date(currentCalendarDate.getFullYear(), currentCalendarDate.getMonth(), 1);
		const lastDay = new Date(currentCalendarDate.getFullYear(), currentCalendarDate.getMonth() + 1, 0);
		
		// Ajuste para que Lunes sea el primer día (0=Dom, 1=Lun...)
		let startOffset = firstDay.getDay() - 1;
		if (startOffset === -1) startOffset = 6;

		// Celdas vacías iniciales
		for (let i = 0; i < startOffset; i++) {
			grid.appendChild(document.createElement('div'));
		}

		// Eventos del mes
		const events = await calendarRepo.listEvents(firstDay.getTime(), lastDay.getTime());

		for (let d = 1; d <= lastDay.getDate(); d++) {
			const cell = document.createElement('div');
			cell.className = 'calendar-day-cell';
			cell.innerHTML = `<span class="day-number">${d}</span>`;
			
			const dayStart = new Date(currentCalendarDate.getFullYear(), currentCalendarDate.getMonth(), d, 0, 0, 0).getTime();
			const dayEnd = new Date(currentCalendarDate.getFullYear(), currentCalendarDate.getMonth(), d, 23, 59, 59).getTime();
			
			const dayEvents = events.filter(e => e.startTime >= dayStart && e.startTime <= dayEnd);
			dayEvents.forEach(e => {
				const evEl = document.createElement('div');
				evEl.className = `calendar-event-item ${e.type}`;
				evEl.textContent = e.title;
				evEl.title = `${e.title}\n${new Date(e.startTime).toLocaleTimeString()} - ${new Date(e.endTime).toLocaleTimeString()}`;
				evEl.setAttribute('data-event-id', e.id);
				evEl.addEventListener('click', (ev) => {
					ev.stopPropagation();
					showEventDetails(e.id);
				});
				cell.appendChild(evEl);
			});

			grid.appendChild(cell);
		}
	}

