				month: "short",
				hour: "2-digit",
				minute: "2-digit",
			});
			const statusIcon = isMine
				? msg.status === "sent"
					? "✓"
					: msg.status === "received"
						? "✓✓"
						: "..."
				: "";

			div.innerHTML = `
				${isGroup && !isMine ? `<div class="msg-sender">${msg.senderUsername || "Alguien"}</div>` : ""}
				<div class="invite-card-content">
