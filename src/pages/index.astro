	});

	async function broadcastSystemMessage(
		action: string,
		data: any,
		customParticipants?: string[],
	) {
		if (!currentChatId) return;

		const { ciphertext, iv } = await encryptText(
			JSON.stringify(data),
			currentChatId,
		);
		const msgId = Math.random().toString(36).substring(7);

		const systemMsg: any = {
			id: msgId,
			senderPubKey: myIdentity.publicKey,
			senderUsername: myIdentity.username,
			groupId: currentChatId,
			content: ciphertext,
			timestamp: Date.now(),
			type: "system",
			systemAction: action,
			status: "sent",
			iv,
		};

		const participants = customParticipants || currentGroupParticipants;
		const others = participants.filter((p) => p !== myIdentity.publicKey);

		await Promise.all(
			others.map(async (p) => {
				try {
					await p2p.sendP2PMessage(p, systemMsg);
				} catch (e) {}
			}),
		);

		await chatRepo.addMessage(currentChatId, {
			...systemMsg,
			content: JSON.stringify(data),
		} as any);
	}

