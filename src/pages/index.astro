	window.addEventListener("bitmeet:send-message", async (e: any) => {
		const { chatId, content } = e.detail;
		console.log("[BitMeet] Enviando mensaje desde overlay a:", chatId);

		const chat = await (window as any).chatRepo.getChat(chatId);
		if (!chat) return;

		const message = {
			id: crypto.randomUUID(),
			senderPubKey: (window as any).myIdentity.publicKey,
			senderUsername: (window as any).myIdentity.username,
			content,
			timestamp: Date.now(),
			type: "text",
			status: "sent",
			iv: "" // Mensajes de overlay por ahora van sin cifrar en el canal interno o se cifran luego
		};

		const updatedChat = await (window as any).chatRepo.getChat(chatId);
		if (updatedChat) {
			updatedChat.lastUpdate = message.timestamp;
			await (window as any).chatRepo.saveChat(updatedChat);
		}

		await (window as any).chatRepo.addMessage(chatId, message as any);

		// Notificar al overlay (auto-feedback)
		window.dispatchEvent(
			new CustomEvent("bitmeet:new-message", {
				detail: { chatId, message },
			}),
		);

		// Enviar a los demás
		if (chat.type === "group") {
			chat.participants.forEach((p) => {
				if (p !== (window as any).myIdentity.publicKey) {
					p2p.sendP2PMessage(p, {
						type: "text",
						content,
						chatId,
					}).catch(() => {});
				}
			});
		} else {
			const other = chat.participants.find(
				(p) => p !== (window as any).myIdentity.publicKey,
			);
			if (other) {
				p2p.sendP2PMessage(other, {
					type: "text",
					content,
					chatId,
				});
			}
		}
	});

	async function loadContacts() {
		const savedContacts = await chatRepo.listContacts();
		const activeChats = await chatRepo.listAllChats();
		const colleagues = await bitid.getColleagues();

		// Filtrar bloqueados
		const filteredSaved = savedContacts.filter((c) => !c.isBlocked);

		// Fusionar listas de contactos directos
		const directContacts: any[] = [...filteredSaved];

		colleagues.forEach((c) => {
			const existing = directContacts.find(
				(a) => a.publicKey === c.public_key,
			);
			if (!existing) {
				directContacts.push({
					publicKey: c.public_key,
					username: c.username,
					online_status: c.online_status,
				});
			} else {
				existing.online_status = c.online_status;
			}
		});

		// Grupos y chats activos
		const groups: any[] = [];
		const otherDirects: any[] = [];

		for (const chat of activeChats) {
			// Ordenar mensajes por timestamp para asegurar que el "último" sea el más reciente cronológicamente
			const sortedMessages = [...chat.messages].sort((a, b) => a.timestamp - b.timestamp);
			const lastMsg = sortedMessages.length > 0 ? sortedMessages[sortedMessages.length - 1] : null;
			
			let lastMsgText = "";
			let isUnread = false;

			if (lastMsg) {
				const isMe = lastMsg.senderPubKey === myIdentity.publicKey;
				const sender = isMe
					? "Tú"
					: lastMsg.senderUsername || "Él/Ella";
				let content = lastMsg.content;
				if (lastMsg.type === "file") content = "📎 Archivo";
				if (lastMsg.type === "system") content = "Mensaje de sistema";
				lastMsgText = `${sender}: ${content}`;

				// Definir si es un mensaje no leído
				// Si nunca se ha leído el chat (lastReadTimestamp undefined), solo marcamos unread si es RECIENTE (< 24h)
				// Si se ha leído, comparamos timestamps. Solo marcamos unread si el último mensaje NO es mío.
				if (!isMe) {
					if (chat.lastReadTimestamp) {
						isUnread = lastMsg.timestamp > chat.lastReadTimestamp;
					} else {
						// Si no hay registro de lectura, solo es unread si el mensaje tiene menos de 24 horas
						const oneDayAgo = Date.now() - 24 * 60 * 60 * 1000;
						isUnread = lastMsg.timestamp > oneDayAgo;
					}
				}
			}

			if (chat.type === "group") {
				groups.push({
					id: chat.id,
					username: chat.name || "Grupo sin nombre",
					isGroup: true,
					participants: chat.participants,
					lastUpdate: chat.lastUpdate,
					lastMessage: lastMsgText,
					isUnread,
				});
				continue;
			}

			const otherPubKey = chat.participants.find(
				(p) => p !== myIdentity.publicKey,
			);
			if (!otherPubKey) continue;

			const existing = directContacts.find(
				(a) => a.publicKey === otherPubKey,
			);
			const contact = await chatRepo.getContact(otherPubKey);
			if (contact?.isBlocked) continue;

			if (!existing) {
				const otherMsgWithName = [...chat.messages]
					.reverse()
					.find(
						(m) =>
							m.senderPubKey === otherPubKey &&
							(m as any).senderUsername,
					);
				const displayName =
					contact?.username ||
					(otherMsgWithName as any)?.senderUsername ||
					`Desconocido (${otherPubKey.substring(0, 6)})`;

				otherDirects.push({
					publicKey: otherPubKey,
					username: displayName,
					isNew: true,
					lastUpdate: chat.lastUpdate,
					lastMessage: lastMsgText,
					isUnread,
				});
			} else {
				if (existing.username.includes("Desconocido")) {
					const otherMsgWithName = [...chat.messages]
						.reverse()
						.find(
							(m) =>
								m.senderPubKey === otherPubKey &&
								(m as any).senderUsername,
						);
					if (otherMsgWithName)
						existing.username = (
							otherMsgWithName as any
						).senderUsername;
				}
				existing.lastUpdate = chat.lastUpdate;
				existing.lastMessage = lastMsgText;
				existing.isUnread = isUnread;
			}
		}

		// Ordenar todo por última actividad
		const all = [...groups, ...directContacts, ...otherDirects].sort(
			(a, b) => (b.lastUpdate || 0) - (a.lastUpdate || 0),
		);

		// Actualizar estados de conexión en tiempo real y disparar auto-discovery
		await Promise.all(
			all
				.filter((c) => !c.isGroup)
				.map(async (c) => {
					// Consultar presencia global (Firebase + P2P)
					const status = await p2p.getPresence(c.publicKey);
					c.online_status = status;

					// Si no está conectado a nivel P2P pero Firebase dice que está online, 
					// p2p.getPresence ya dispara la reconexión proactiva internamente.
					if (status === "offline") {
						p2p.discover(c.publicKey);
					}
				}),
		);

		renderContactList(all);
		updateActiveChatPresence();
	}

	async function updateActiveChatPresence() {
		if (currentChatType !== "direct" || !currentChatPubKey) return;

		const statusEl = document.getElementById("active-chat-status")!;
		const statusDot = document.getElementById("active-chat-status-dot")!;

		const status = await p2p.getPresence(currentChatPubKey);
		
		const statusLabels: Record<string, string> = {
			available: "Disponible",
			busy: "No disponible",
			"in-call": "En llamada",
			offline: "Desconectado"
		};

		statusEl.textContent = statusLabels[status as string] || "Desconectado";
		statusDot.className = `status-dot ${status}`;
	}

