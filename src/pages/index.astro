			...contacts,
			...colleagues.map((c) => ({
				publicKey: c.public_key,
				username: c.username,
			})),
		];

		const filtered = all.filter(
			(c) =>
				c.username.toLowerCase().includes(q) &&
				!selectedParticipants.find((p) => p.pubKey === c.publicKey),
		);

		if (participantResults) {
