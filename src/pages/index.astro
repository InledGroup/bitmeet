	async function renderCalendar() {
		const view =
			(document.getElementById("cal-view-selector") as HTMLSelectElement)
				?.value || "month";
		const grid = document.getElementById("calendar-grid");
		if (!grid) return;

		grid.className = `calendar-grid ${view}-view`;
		grid.innerHTML = "";

		if (view === "month") {
			await renderMonthView(grid);
		} else {
			if (view === "week") await renderWeekView(grid);
			else if (view === "day") await renderDayView(grid);

			// Autoscroll a una hora razonable (8:00 AM) para que no se vea vacío arriba
			setTimeout(() => {
				const viewport = grid.parentElement;
				if (viewport) viewport.scrollTop = 8 * 80;
			}, 50);
		}
	}

	async function renderMonthView(grid: HTMLElement) {
		const periodEl = document.getElementById("cal-current-period");
		if (periodEl) {
			periodEl.textContent = currentCalendarDate.toLocaleString("es-ES", {
				month: "long",
				year: "numeric",
			});
		}

		// Cabecera días
		const days = ["Lun", "Mar", "Mié", "Jue", "Vie", "Sáb", "Dom"];
		days.forEach((d) => {
			const cell = document.createElement("div");
			cell.className = "calendar-day-header";
			cell.textContent = d;
			grid.appendChild(cell);
		});

		const firstDay = new Date(
			currentCalendarDate.getFullYear(),
			currentCalendarDate.getMonth(),
			1,
		);
		const lastDay = new Date(
			currentCalendarDate.getFullYear(),
			currentCalendarDate.getMonth() + 1,
			0,
		);

		let startOffset = firstDay.getDay() - 1;
		if (startOffset === -1) startOffset = 6;

		for (let i = 0; i < startOffset; i++) {
			grid.appendChild(document.createElement("div"));
		}

		const events = await calendarRepo.listEvents(
			firstDay.getTime(),
			lastDay.getTime(),
		);

		for (let d = 1; d <= lastDay.getDate(); d++) {
			const cell = document.createElement("div");
			cell.className = "calendar-day-cell";
			cell.innerHTML = `<span class="day-number">${d}</span>`;

			const dayStart = new Date(
				currentCalendarDate.getFullYear(),
				currentCalendarDate.getMonth(),
				d,
				0,
				0,
				0,
			).getTime();
			const dayEnd = new Date(
				currentCalendarDate.getFullYear(),
				currentCalendarDate.getMonth(),
				d,
				23,
				59,
				59,
			).getTime();

			const dayEvents = events.filter(
				(e) => e.startTime >= dayStart && e.startTime <= dayEnd,
			);
			dayEvents.forEach((e) => {
				const evEl = document.createElement("div");
				evEl.className = `calendar-event-item ${e.type}`;
				evEl.textContent = e.title;
				evEl.title = `${e.title}\n${new Date(e.startTime).toLocaleTimeString()} - ${new Date(e.endTime).toLocaleTimeString()}`;
				evEl.setAttribute("data-event-id", e.id);
				evEl.addEventListener("click", (ev) => {
					ev.stopPropagation();
					showEventDetails(e.id);
				});
				cell.appendChild(evEl);
			});
			grid.appendChild(cell);
		}
	}

	async function renderWeekView(grid: HTMLElement) {
		const periodEl = document.getElementById("cal-current-period");

		// Calcular inicio de semana (Lunes)
		const startOfWeek = new Date(currentCalendarDate);
		const day = startOfWeek.getDay();
		const diff = startOfWeek.getDate() - day + (day === 0 ? -6 : 1);
		startOfWeek.setDate(diff);
		startOfWeek.setHours(0, 0, 0, 0);

		const endOfWeek = new Date(startOfWeek);
		endOfWeek.setDate(endOfWeek.getDate() + 6);
		endOfWeek.setHours(23, 59, 59, 999);

		if (periodEl) {
			periodEl.textContent = `${startOfWeek.getDate()} - ${endOfWeek.getDate()} ${endOfWeek.toLocaleString("es-ES", { month: "short" })}`;
		}

		grid.innerHTML = `
			<div class="time-axis"></div>
			<div class="view-content"></div>
		`;

		const timeAxis = grid.querySelector(".time-axis")!;
		const content = grid.querySelector(".view-content")!;

		// Eje de tiempo
		for (let h = 0; h < 24; h++) {
			const label = document.createElement("div");
			label.className = "time-label";
			label.textContent = `${h}:00`;
			timeAxis.appendChild(label);
		}

		const events = await calendarRepo.listEvents(
			startOfWeek.getTime(),
			endOfWeek.getTime(),
		);

		// Columnas de días
		for (let i = 0; i < 7; i++) {
			const currentDay = new Date(startOfWeek);
			currentDay.setDate(startOfWeek.getDate() + i);

			const column = document.createElement("div");
			column.className = "day-column";
			column.innerHTML = `
				<div class="column-header">
					${currentDay.toLocaleString("es-ES", { weekday: "short" })} ${currentDay.getDate()}
				</div>
			`;

			const dayStart = new Date(currentDay).setHours(0, 0, 0, 0);
			const dayEnd = new Date(currentDay).setHours(23, 59, 59, 999);

			const dayEvents = events.filter(
				(e) => e.startTime >= dayStart && e.startTime <= dayEnd,
			);

			dayEvents.forEach((e) => {
				const evEl = createRealSpaceEvent(e);
				column.appendChild(evEl);
			});

			content.appendChild(column);
		}
	}

	async function renderDayView(grid: HTMLElement) {
		const periodEl = document.getElementById("cal-current-period");
		if (periodEl) {
			periodEl.textContent = currentCalendarDate.toLocaleDateString(
				"es-ES",
				{ weekday: "long", day: "numeric", month: "long" },
			);
		}

		grid.innerHTML = `
			<div class="time-axis"></div>
			<div class="view-content"></div>
		`;

		const timeAxis = grid.querySelector(".time-axis")!;
		const content = grid.querySelector(".view-content")!;

		for (let h = 0; h < 24; h++) {
			const label = document.createElement("div");
			label.className = "time-label";
			label.textContent = `${h}:00`;
			timeAxis.appendChild(label);
		}

		const dayStart = new Date(currentCalendarDate).setHours(0, 0, 0, 0);
		const dayEnd = new Date(currentCalendarDate).setHours(23, 59, 59, 999);
		const events = await calendarRepo.listEvents(dayStart, dayEnd);

		const column = document.createElement("div");
		column.className = "day-column";

		events.forEach((e) => {
			const evEl = createRealSpaceEvent(e);
			column.appendChild(evEl);
		});

		content.appendChild(column);
	}

	function createRealSpaceEvent(e: any) {
		const date = new Date(e.startTime);
		const startMins = date.getHours() * 60 + date.getMinutes();
		const durationMins = Math.max(30, (e.endTime - e.startTime) / 60000);

		const top = (startMins / 60) * 80 + 40; // 80px por hora, +40px de header
		const height = (durationMins / 60) * 80;

		const evEl = document.createElement("div");
		evEl.className = `calendar-event-item ${e.type} real-space`;
		evEl.style.top = `${top}px`;
		evEl.style.height = `${height}px`;

		evEl.innerHTML = `
			<strong>${e.title}</strong>
			<span class="event-time">${new Date(e.startTime).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" })}</span>
		`;

		evEl.addEventListener("click", (ev) => {
			ev.stopPropagation();
			showEventDetails(e.id);
		});
		return evEl;
	}

	async function showEventDetails(eventId: string) {
		currentlyOpenEventId = eventId;
		const event = await calendarRepo.getEvent(eventId);
		if (!event) return;

		const contentEl = document.getElementById("event-detail-content");
		const titleEl = document.getElementById("detail-event-title");
		if (!contentEl || !titleEl) return;

		titleEl.textContent = event.title;

		const format = (d: number) =>
