	async function loadCallsView() {
		const invitations = await calendarRepo.listInvitations();
		const history = await callsRepo.listCallHistory();

		const invList = document.getElementById("calendar-invitations-list");
		const callList = document.getElementById("calls-history-list");

		if (invList) {
			if (invitations.length === 0) {
				invList.innerHTML =
					'<div class="empty-results">No tienes invitaciones pendientes</div>';
			} else {
				invList.innerHTML = invitations
					.map(
						(inv) => `
					<div class="item-card invitation-card ${inv.status}">
						<div class="item-info">
							<strong>${inv.title}</strong>
							<span>Organizado por @${inv.organizerUsername}</span>
							<small>${new Date(inv.startTime).toLocaleString()} - ${new Date(inv.endTime).toLocaleTimeString()}</small>
						</div>
						<div class="item-actions">
							${
								inv.status === "pending"
									? `
								<button class="btn-accept-inv" data-id="${inv.id}">Aceptar</button>
								<button class="btn-reject-inv" data-id="${inv.id}">Rechazar</button>
							`
									: `<span class="status-badge">${inv.status === "accepted" ? "Aceptada" : "Rechazada"}</span>`
							}
						</div>
					</div>
				`,
					)
					.join("");

				invList.querySelectorAll(".btn-accept-inv").forEach((btn) => {
					btn.addEventListener("click", async (e) => {
						const id = (
							e.currentTarget as HTMLElement
						).getAttribute("data-id")!;
						await respondToInvitation(id, "accepted");
					});
				});

				invList.querySelectorAll(".btn-reject-inv").forEach((btn) => {
					btn.addEventListener("click", async (e) => {
						const id = (
							e.currentTarget as HTMLElement
						).getAttribute("data-id")!;
						await respondToInvitation(id, "rejected");
					});
				});
			}
		}

		if (callList) {
			if (history.length === 0) {
				callList.innerHTML =
					'<div class="empty-results">Historial de llamadas vacío</div>';
			} else {
				callList.innerHTML = history
					.map(
						(call) => `
					<div class="item-card call-card">
						<div class="item-icon ${call.type}">
							${call.type === "missed" ? "✕" : call.type === "incoming" ? "↙" : "↗"}
						</div>
						<div class="item-info">
							<strong>@${call.remoteUsername}</strong>
							<span>${call.isVideo ? "Videollamada" : "Llamada de voz"} ${call.type === "missed" ? "perdida" : ""}</span>
							<small>${new Date(call.startTime).toLocaleString()} ${call.duration ? `· ${Math.floor(call.duration / 60)}m ${call.duration % 60}s` : ""}</small>
						</div>
						<div class="item-actions">
							<button class="btn-call-back" data-pubkey="${call.remotePubKey}">Llamar</button>
						</div>
					</div>
				`,
					)
					.join("");

				callList.querySelectorAll(".btn-call-back").forEach((btn) => {
					btn.addEventListener("click", (e) => {
						const pubKey = (
							e.currentTarget as HTMLElement
						).getAttribute("data-pubkey")!;
						// Lógica para devolver llamada
						currentChatPubKey = pubKey;
						document.getElementById("btn-call-video")?.click();
					});
				});
			}
		}
	}

	async function respondToInvitation(
		id: string,
		status: "accepted" | "rejected",
	) {
		const inv = await calendarRepo.getInvitation(id);
		if (!inv) return;

		await calendarRepo.updateInvitationStatus(id, status);

		// Notificar al organizador
		try {
			await p2p.sendP2PMessage(inv.organizerPubKey, {
				type: "calendar-response",
				eventId: inv.eventId,
				invitationId: id,
				status: status,
				responderPubKey: myIdentity.publicKey,
				responderUsername: myIdentity.username,
			});
		} catch (e) {}

		if (status === "accepted") {
			// Añadir al calendario personal
			await calendarRepo.saveEvent({
				id: inv.eventId,
				title: inv.title,
				description: inv.description,
				startTime: inv.startTime,
				endTime: inv.endTime,
				type: "meeting",
				meetingLink: inv.meetingLink,
				isNative: inv.isNative,
				organizerPubKey: inv.organizerPubKey,
				participants: [], // Solo yo en mi copia local
				status: "confirmed",
			});
		}

		loadCallsView();
	}
