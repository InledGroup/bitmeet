	document.getElementById('detail-event-btn-delete')?.addEventListener('click', async () => {
		if (!currentlyOpenEventId) return;

		if (confirm("¿Estás seguro de que quieres eliminar este evento? Esta acción no se puede deshacer.")) {
			const event = await calendarRepo.getEvent(currentlyOpenEventId);
			if (event) {
				// Notificar a los participantes
				if (event.participants && event.participants.length > 0) {
					event.participants.forEach(async (pubKey) => {
						try {
							await p2p.sendP2PMessage(pubKey, {
								type: 'calendar-cancel',
								eventId: event.id,
							});
						} catch (e) {}
					});
				}
			}

			await calendarRepo.deleteEvent(currentlyOpenEventId);
			eventDetailModal?.classList.add('hidden');
			renderCalendar();
		}
	});


	const participantSearch = document.getElementById('participant-search') as HTMLInputElement;
	const participantResults = document.getElementById('participant-results');

	participantSearch?.addEventListener('input', async () => {
		const q = participantSearch.value.trim().toLowerCase();
		if (q.length < 2) {
			participantResults?.classList.add('hidden');
			return;
		}

		const contacts = await chatRepo.listContacts();
		const colleagues = await bitid.getColleagues();
		const all = [...contacts, ...colleagues.map(c => ({ publicKey: c.public_key, username: c.username }))];
		
		const filtered = all.filter(c => c.username.toLowerCase().includes(q) && !selectedParticipants.find(p => p.pubKey === c.publicKey));

		if (participantResults) {
			participantResults.innerHTML = filtered.map(c => `
				<div class="mini-result-item" data-pubkey="${c.publicKey}" data-username="${c.username}">
					@${c.username}
				</div>
			`).join('');
			participantResults.classList.remove('hidden');

			participantResults.querySelectorAll('.mini-result-item').forEach(item => {
				item.addEventListener('click', (e) => {
					const pubKey = (e.currentTarget as HTMLElement).getAttribute('data-pubkey')!;
					const username = (e.currentTarget as HTMLElement).getAttribute('data-username')!;
					selectedParticipants.push({ pubKey, username });
					updateParticipantChips();
					participantSearch.value = '';
					participantResults.classList.add('hidden');
				});
			});
		}
	});

	function updateParticipantChips() {
		const container = document.getElementById('selected-participants');
		if (container) {
			container.innerHTML = selectedParticipants.map(p => `
				<div class="participant-chip">
					${p.username}
					<button type="button" data-pubkey="${p.pubKey}">✕</button>
				</div>
			`).join('');

			container.querySelectorAll('button').forEach(btn => {
				btn.addEventListener('click', () => {
					const pubKey = btn.getAttribute('data-pubkey');
					selectedParticipants = selectedParticipants.filter(p => p.pubKey !== pubKey);
					updateParticipantChips();
				});
			});
		}
	}

	document.getElementById('event-form')?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const title = (document.getElementById('event-title') as HTMLInputElement).value;
		const start = new Date((document.getElementById('event-start') as HTMLInputElement).value).getTime();
		const end = new Date((document.getElementById('event-end') as HTMLInputElement).value).getTime();
		const type = (document.querySelector('input[name="event-type"]:checked') as HTMLInputElement).value as 'meeting' | 'busy';
		const isNative = (document.getElementById('event-is-native') as HTMLInputElement).checked;
		const link = (document.getElementById('event-link') as HTMLInputElement).value;
		const desc = (document.getElementById('event-desc') as HTMLTextAreaElement).value;

		const eventId = Math.random().toString(36).substring(7);
		const nativeLink = isNative ? `${window.location.origin}/room/${eventId}` : link;

		const event: any = {
			id: eventId,
			title,
			description: desc,
			startTime: start,
			endTime: end,
			type,
			meetingLink: nativeLink,
			isNative,
			organizerPubKey: myIdentity.publicKey,
			participants: selectedParticipants.map(p => p.pubKey),
			status: 'confirmed'
		};

		await calendarRepo.saveEvent(event);
		
		// Enviar invitaciones P2P
		if (type === 'meeting') {
			selectedParticipants.forEach(async (p) => {
				try {
					await p2p.sendP2PMessage(p.pubKey, {
						type: 'calendar-invite',
						id: Math.random().toString(36).substring(7),
						eventId: eventId,
						organizerPubKey: myIdentity.publicKey,
						organizerUsername: myIdentity.username,
						title,
						description: desc,
						startTime: start,
						endTime: end,
						meetingLink: nativeLink,
						isNative
					});
				} catch (err) {
					console.warn(`No se pudo enviar invitación a @${p.username}. Se reintentará al conectar.`);
				}
			});
		}

		eventModal?.classList.add('hidden');
		renderCalendar();
		alert("Evento guardado");
	});

	// --- FIN LÓGICA DE CALENDARIO ---
	async function loadChatHistory(chatId: string) {
		const container = document.getElementById('messages-list')!;
		container.innerHTML = '<div class="loading-state">Cargando...</div>';
		const chat = await chatRepo.getChat(chatId);
		container.innerHTML = '';
		if (chat) {
			chat.messages.forEach(m => renderMessage(m));
			scrollToBottom();
		}
	}

	async function loadFilePreview(msgId: string) {
		const msgEl = document.querySelector(`.message-bubble[data-id="${msgId}"]`);
		const previewContainer = msgEl?.querySelector('.file-preview');
		if (!previewContainer) return;

		try {
			const chat = await chatRepo.getChat(currentChatId!);
			const msg = chat?.messages.find(m => m.id === msgId);
			if (!msg || msg.type !== 'file') return;

			const fileMeta = JSON.parse(msg.content);
			if (!fileMeta.type.startsWith('image/')) return;

			if (!torrentClient) torrentClient = await getWebTorrentClient();
			
			const onDone = async (t: any) => {
				try {
					const file = t.files[0];
					const encryptedBuf = await file.arrayBuffer();
					
					// GUARDAR PARA RE-SEEDING FUTURO
					try { await chatRepo.saveFileData(msgId, encryptedBuf, fileMeta.magnetURI); } catch(e) {}

					const key = await importFileKey(fileMeta.key);
					const iv = new Uint8Array(atob(fileMeta.iv).split('').map(c => c.charCodeAt(0)));
					
					const decryptedBuf = await decryptFile(encryptedBuf, key, iv);
					const blob = new Blob([decryptedBuf], { type: fileMeta.type });
					const url = URL.createObjectURL(blob);
					previewContainer.innerHTML = `<img src="${url}" alt="Preview" class="preview-img" onclick="window.open('${url}', '_blank')" />`;
					previewContainer.classList.remove('loading');
				} catch (e) {
					console.error("Preview decryption error:", e);
				}
			};

			let torrent = torrentClient.torrents.find((t: any) => 
				t.magnetURI === fileMeta.magnetURI || t.infoHash === fileMeta.magnetURI || t.infoHash === fileMeta.magnetURI.split('btih:')[1]?.split('&')[0]
			);

			if (torrent && typeof torrent.on === 'function') {
				if (torrent.done) onDone(torrent);
				else torrent.on('done', () => onDone(torrent));
			} else {
				try {
					torrentClient.add(fileMeta.magnetURI, { announce: TRACKERS }, (t: any) => {
						if (t && typeof t.on === 'function') t.on('done', () => onDone(t));
					});
				} catch (e) {
					const retry = torrentClient.get(fileMeta.magnetURI);
					if (retry && typeof retry.on === 'function') onDone(retry);
				}
			}
		} catch (e) {
			console.error("Preview load error:", e);
		}
	}

	function renderMessage(msg: any) {
		const container = document.getElementById('messages-list')!;
		const loading = container.querySelector('.loading-state');
		if (loading) loading.remove();

		const isMine = msg.senderPubKey === myIdentity.publicKey;
		const isGroup = currentChatType === 'group';
		const isSystem = msg.type === 'system';
		const isFile = msg.type === 'file';

		const div = document.createElement('div');
		div.setAttribute('data-id', msg.id);
		div.setAttribute('data-timestamp', msg.timestamp.toString());

		if (isSystem) {
			div.className = 'system-message';
			let systemText = msg.content;
			try {
				const data = JSON.parse(msg.content);
				const sender = msg.senderPubKey === myIdentity.publicKey ? 'Tú' : `@${msg.senderUsername}`;

				if (msg.systemAction === 'group_created') systemText = `🏗️ ${sender} creó el grupo "${data.name}"`;
				else if (msg.systemAction === 'group_renamed') systemText = `✏️ ${sender} renombró el grupo a "${data.newName}"`;
				else if (msg.systemAction === 'member_added') systemText = `➕ ${sender} añadió nuevos participantes`;
				else if (msg.systemAction === 'member_removed') systemText = `🚫 ${sender} expulsó a un participante`;
				else if (msg.systemAction === 'member_left') systemText = `🚪 ${sender} abandonó el grupo`;
			} catch (e) {}

			div.innerHTML = `<span>${systemText}</span>`;
		} else if (isFile) {
			div.className = `message-bubble ${isMine ? 'mine' : 'theirs'} file-message`;
			let fileMeta = { name: 'Archivo', size: 0, type: '' };
			try { fileMeta = JSON.parse(msg.content); } catch(e) {}
			
			const isImage = fileMeta.type && fileMeta.type.startsWith('image/');
			const statusIcon = isMine ? (msg.status === 'sent' ? '✓' : (msg.status === 'received' ? '✓✓' : '...')) : '';

			div.innerHTML = `
				${isGroup && !isMine ? `<div class="msg-sender">${msg.senderUsername || 'Alguien'}</div>` : ''}
				<div class="file-content">
					${isImage ? `<div class="file-preview loading" data-id="${msg.id}"><div class="spinner"></div></div>` : ''}
					<div class="file-info">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="file-icon"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"></path><polyline points="13 2 13 9 20 9"></polyline></svg>
						<div class="file-details">
							<div class="file-name" title="${fileMeta.name}">${fileMeta.name}</div>
							<div class="file-size">${(fileMeta.size / 1024 / 1024).toFixed(2)} MB</div>
						</div>
						<button class="file-download-btn" onclick="downloadFile('${msg.id}')" title="Descargar">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
						</button>
					</div>
					<div class="file-progress hidden"></div>
				</div>
				<div class="msg-meta">
					${new Date(msg.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
					<span class="msg-status">${statusIcon}</span>
				</div>
			`;

			if (isImage) {
				setTimeout(() => loadFilePreview(msg.id), 100);
			}
		} else {
			div.className = `message-bubble ${isMine ? 'mine' : 'theirs'}`;
			const statusIcon = isMine ? (msg.status === 'sent' ? '✓' : (msg.status === 'received' ? '✓✓' : '...')) : '';
			div.innerHTML = `
				${isGroup && !isMine ? `<div class="msg-sender">${msg.senderUsername || 'Alguien'}</div>` : ''}
				<div class="msg-content">${msg.content}</div>
				<div class="msg-meta">
					${new Date(msg.timestamp).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
					<span class="msg-status">${statusIcon}</span>
				</div>
			`;
		}
		container.appendChild(div);
	}
	function updateMessageUIStatus(msgId: string, status: string) {
		const msgEl = document.querySelector(`.message-bubble[data-id="${msgId}"]`);
		if (msgEl) {
			const statusSpan = msgEl.querySelector('.msg-status');
			if (statusSpan) {
				statusSpan.textContent = status === 'sent' ? '✓' : (status === 'received' ? '✓✓' : '...');
			}
		}
	}

	function scrollToBottom() {
		const container = document.getElementById('messages-list')!;
		container.scrollTop = container.scrollHeight;
	}

	btnAttach?.addEventListener('click', () => fileInput?.click());
	fileInput?.addEventListener('change', async (e: any) => {
		const file = e.target.files[0];
		if (!file || !currentChatId) return;
		
		const isGroup = currentChatType === 'group';
		if (!isGroup && !currentChatPubKey) return;

		// 1. Cifrar archivo
		const key = await generateFileKey();
		const { iv, data } = await encryptFile(file, key);
		const keyStr = await exportFileKey(key);
		const ivStr = btoa(String.fromCharCode(...iv));

		// 2. Iniciar WebTorrent
		if (!torrentClient) torrentClient = await getWebTorrentClient();
		const encryptedBlob = new Blob([data], { type: 'application/octet-stream' });
		
		torrentClient.seed(encryptedBlob, { 
			name: file.name + '.encrypted',
			announce: TRACKERS 
		}, async (torrent: any) => {
			const timestamp = Date.now();
			const msgId = Math.random().toString(36).substring(7);
			
			// GUARDAR EN INDEXEDDB PARA AUTO-RESEEDING
			try { await chatRepo.saveFileData(msgId, data, torrent.magnetURI); } catch(e) {}

			const fileMetadata = {
				name: file.name,
				size: file.size,
				type: file.type,
				magnetURI: torrent.magnetURI,
				iv: ivStr,
				key: keyStr
			};

			const { ciphertext, iv: msgIv } = await encryptText(JSON.stringify(fileMetadata), currentChatId!);

			const rawMessage: any = { 
				id: msgId, 
				senderPubKey: myIdentity.publicKey, 
				senderUsername: myIdentity.username,
				content: JSON.stringify(fileMetadata), 
				timestamp, 
				type: 'file',
				status: 'pending', 
				iv: msgIv 
			};

			if (isGroup) {
				rawMessage.groupId = currentChatId;
			} else {
				rawMessage.receiverPubKey = currentChatPubKey;
			}

			renderMessage(rawMessage);
			scrollToBottom();

			const p2pPayload = { 
				type: 'chat', 
				msgType: 'file',
				id: msgId, 
				senderPubKey: myIdentity.publicKey, 
				senderUsername: myIdentity.username,
				content: ciphertext, 
				timestamp, 
				iv: msgIv,
				groupId: isGroup ? currentChatId : undefined
			};

			if (isGroup) {
				const others = currentGroupParticipants.filter(p => p !== myIdentity.publicKey);
				let sentCount = 0;
				await Promise.all(others.map(async (pubKey) => {
					try {
						await p2p.sendP2PMessage(pubKey, p2pPayload);
						sentCount++;
					} catch (err) {}
				}));
				if (sentCount > 0) {
					rawMessage.status = 'sent';
					updateMessageUIStatus(msgId, 'sent');
				}
			} else {
				try { 
					await p2p.sendP2PMessage(currentChatPubKey!, p2pPayload); 
					rawMessage.status = 'sent'; 
					updateMessageUIStatus(msgId, 'sent');
				} catch (err) {}
			}
			
			await chatRepo.addMessage(currentChatId!, rawMessage);
			loadContacts();
		});

		fileInput.value = '';
	});

	document.getElementById('chat-form')?.addEventListener('submit', async (e) => {
		e.preventDefault();
		const input = document.getElementById('chat-input') as HTMLInputElement;
		const text = input.value.trim();
		if (!text || !currentChatId) return;
		
		const isGroup = currentChatType === 'group';
		if (!isGroup && !currentChatPubKey) return;

		input.value = '';
		const timestamp = Date.now();
		const msgId = Math.random().toString(36).substring(7);
		const { ciphertext, iv } = await encryptText(text, currentChatId);
		
		const rawMessage: any = { 
			id: msgId, 
			senderPubKey: myIdentity.publicKey, 
			senderUsername: myIdentity.username,
			content: text, 
			timestamp, 
			status: 'pending', 
			iv 
		};

		if (isGroup) {
			rawMessage.groupId = currentChatId;
		} else {
			rawMessage.receiverPubKey = currentChatPubKey;
		}

		renderMessage(rawMessage);
		scrollToBottom();

		const p2pPayload = { 
			type: 'chat', 
			msgType: 'text',
			id: msgId, 
			senderPubKey: myIdentity.publicKey, 
			senderUsername: myIdentity.username,
			content: ciphertext, 
			timestamp, 
			iv,
			groupId: isGroup ? currentChatId : undefined
		};

		if (isGroup) {
			// Broadcast a todos los participantes excepto yo
			const others = currentGroupParticipants.filter(p => p !== myIdentity.publicKey);
			let sentCount = 0;
			await Promise.all(others.map(async (pubKey) => {
				try {
					await p2p.sendP2PMessage(pubKey, p2pPayload);
					sentCount++;
				} catch (err) {
					console.warn(`Could not send message to ${pubKey}`);
				}
			}));
			if (sentCount > 0) {
				rawMessage.status = 'sent';
				updateMessageUIStatus(msgId, 'sent');
			}
		} else {
			try { 
				await p2p.sendP2PMessage(currentChatPubKey!, p2pPayload); 
				rawMessage.status = 'sent'; 
				updateMessageUIStatus(msgId, 'sent');
			} catch (err) { 
				console.warn("Peer offline."); 
			}
		}
		
		await chatRepo.addMessage(currentChatId, rawMessage);
		loadContacts(); // Refrescar para mover al principio
	});
document.getElementById('btn-hero-new-chat')?.addEventListener('click', () => {
	globalSearch?.focus();
});

// Logout
document.getElementById('btn-logout')?.addEventListener('click', () => {
	bitid.lock();
	window.location.reload();
});

async function getChatId(pub1: string, pub2: string) {
	const combined = [pub1, pub2].sort().join('-');
	const msgUint8 = new TextEncoder().encode(combined);
	const hashBuffer = await crypto.subtle.digest('SHA-256', msgUint8);
	const hashArray = Array.from(new Uint8Array(hashBuffer));
	return hashArray.map(b => b.toString(16).padStart(2, '0')).join('').substring(0, 16);
}

initApp();
</script>
