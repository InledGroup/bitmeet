	// 3.1 REINTENTO DE MENSAJES PENDIENTES
	async function retryPendingMessages(targetPubKey?: string) {
		if (isRetryingMessages) return;
		isRetryingMessages = true;
		try {
			const chats = await chatRepo.listAllChats();
			for (const chat of chats) {
				const pendingMsgs = chat.messages.filter(
					(m) => m.status === "pending",
				);
				if (pendingMsgs.length === 0) continue;

				if (chat.type === "direct") {
					const otherPubKey = chat.participants.find(
						(p) => p !== myIdentity.publicKey,
					);
					if (!otherPubKey) continue;

					if (targetPubKey && targetPubKey !== otherPubKey) continue;

					let isConnected = await p2p.isConnected(otherPubKey);
					const isOnline =
						isConnected ||
						(await p2p.getPresence(otherPubKey)) !== "offline";

					// Si no está conectado pero sabemos que está online, intentamos forzar conexión
					if (!isConnected && isOnline) {
						console.log(
							`Peer ${otherPubKey} online pero no conectado. Intentando conectar...`,
						);
						const success = await p2p.connectToPeer(otherPubKey);
						if (success) {
							// Esperar un momento a que se establezca el canal de datos
							await new Promise((res) => setTimeout(res, 1000));
							isConnected = await p2p.isConnected(otherPubKey);
						}
					}

					if (!isConnected && !isOnline && !targetPubKey) continue;

					console.log(
						`Re-enviando ${pendingMsgs.length} mensajes a ${otherPubKey}...`,
					);
					for (const msg of pendingMsgs) {
						try {
							let p2pPayload: any;

							if (msg.type === "calendar-invite") {
								// Las invitaciones de calendario las enviamos con su propio tipo para que el receptor las procese
								const data = JSON.parse(msg.content);
								p2pPayload = {
									type: "calendar-invite",
									...data,
									senderPubKey: myIdentity.publicKey,
									senderUsername: myIdentity.username,
								};
							} else {
								const { ciphertext, iv } = await encryptText(
									msg.content,
									chat.id,
								);
								p2pPayload = {
									type:
										msg.type === "system"
											? "system"
											: "chat",
									id: msg.id,
									senderPubKey: myIdentity.publicKey,
									senderUsername: myIdentity.username,
									content: ciphertext,
									timestamp: msg.timestamp,
									iv,
									groupId: undefined,
								};
							}

							await p2p.sendP2PMessage(otherPubKey, p2pPayload);
							await chatRepo.updateMessageStatus(
								chat.id,
								msg.id,
								"sent",
							);
							if (currentChatId === chat.id)
								updateMessageUIStatus(msg.id, "sent");
							console.log(
								`Mensaje ${msg.id} de tipo ${msg.type} re-enviado con éxito.`,
							);
						} catch (e) {
							console.warn(
								`Error al re-enviar mensaje ${msg.id} a ${otherPubKey}:`,
								e,
							);
							// Si falla un mensaje, probablemente la conexión ha caído, paramos este chat
							break;
						}
					}
				} else {
					// Para grupos, intentamos re-enviar si algún participante está conectado
					const others = chat.participants.filter(
						(p) => p !== myIdentity.publicKey,
					);
					for (const msg of pendingMsgs) {
						let sentAtLeastToOne = false;
						let p2pPayload: any;

						if (msg.type === "calendar-invite") {
							const data = JSON.parse(msg.content);
							p2pPayload = {
								type: "calendar-invite",
								...data,
								senderPubKey: myIdentity.publicKey,
								senderUsername: myIdentity.username,
							};
						} else {
							const { ciphertext, iv } = await encryptText(
								msg.content,
								chat.id,
							);
							p2pPayload = {
								type:
									msg.type === "system" ? "system" : "chat",
								id: msg.id,
								senderPubKey: myIdentity.publicKey,
								senderUsername: myIdentity.username,
								content: ciphertext,
								timestamp: msg.timestamp,
								iv,
								groupId: chat.id,
							};
						}

						for (const pubKey of others) {
							try {
								if (targetPubKey && targetPubKey !== pubKey)
									continue;

								// Intentar conectar si está online
								let isConnected = await p2p.isConnected(pubKey);
								if (
									!isConnected &&
									(await p2p.getPresence(pubKey)) !==
										"offline"
								) {
									await p2p.connectToPeer(pubKey);
									// Pequeña espera para conexión inicial
									await new Promise((res) =>
										setTimeout(res, 500),
									);
									isConnected = await p2p.isConnected(pubKey);
								}

								if (isConnected) {
									await p2p.sendP2PMessage(
										pubKey,
										p2pPayload,
									);
									sentAtLeastToOne = true;
								}
							} catch (err) {}
						}

						if (sentAtLeastToOne) {
							await chatRepo.updateMessageStatus(
								chat.id,
								msg.id,
								"sent",
							);
							if (currentChatId === chat.id)
								updateMessageUIStatus(msg.id, "sent");
						}
					}
				}
			}
		} finally {
			isRetryingMessages = false;
		}
	}

	async function syncChat(chatId: string, otherPubKey: string) {
		const chat = await chatRepo.getChat(chatId);
		if (!chat) return;

		const receivedMsgs = chat.messages.filter(
			(m) => m.senderPubKey === otherPubKey,
		);
		const lastReceivedTs =
			receivedMsgs.length > 0
				? Math.max(...receivedMsgs.map((m) => m.timestamp))
				: 0;

		console.log(
			`Enviando sync-ping a ${otherPubKey} para chat ${chatId}. Último recibido: ${new Date(lastReceivedTs).toLocaleTimeString()}`,
		);

		try {
			await p2p.sendP2PMessage(otherPubKey, {
				type: "sync-ping",
				chatId: chatId,
				lastReceivedTimestamp: lastReceivedTs,
				senderPubKey: myIdentity.publicKey,
			});
		} catch (e) {
			console.warn("Error enviando sync-ping", e);
		}
	}

	// 3. P2P Y NOTIFICACIONES DE LLAMADA
	async function startP2P() {
		const savedStatus = (localStorage.getItem("bitmeet_my_status") as any) || "available";
		await p2p.initialize(myIdentity.publicKey, bitid);
		await p2p.setStatus(savedStatus); // Sincronizar estado inicial persistido

		const myDot = document.getElementById("my-status-dot");
		if (myDot) myDot.className = `status-circle ${savedStatus}`;

		// Carga inmediata de contactos
		await loadContacts();
		
		// Sincronización Multi-dispositivo: Intentar conectar con mis otros dispositivos de inmediato
		console.log("[BitMeet] Iniciando auto-sincronización multi-dispositivo...");
		p2p.connectToPeer(myIdentity.publicKey);
		
		// Conexión Ipso Facto: Intentamos conectar con todos los que parezcan online
		const colleagues = await bitid.getColleagues();
		colleagues.forEach(c => {
			p2p.getPresence(c.public_key).then(status => {
				if (status !== 'offline') {
					console.log(`[BitMeet] Auto-connecting to online peer: ${c.username}`);
					p2p.connectToPeer(c.public_key);
				}
			});
		});

		// RE-ACTIVAR SEEDING DE ÚLTIMAS 24H
		try {
			const recentFiles = await chatRepo.listRecentFiles(
				24 * 60 * 60 * 1000,
			);
			if (recentFiles.length > 0) {
				console.log(
					`[BitMeet] Re-seedizando ${recentFiles.length} archivos...`,
				);
				if (!torrentClient) torrentClient = await getWebTorrentClient();
				for (const f of recentFiles) {
					let magnetURI = f.magnetURI;

					// Fallback: si no tiene magnetURI guardado directamente, lo buscamos en los chats (compatibilidad con archivos guardados antes del cambio)
					if (!magnetURI) {
						const chats = await chatRepo.listAllChats();
						for (const c of chats) {
							const msg = c.messages.find(
								(m) => m.id === f.msgId,
							);
							if (msg && msg.type === "file") {
								try {
									magnetURI = JSON.parse(
										msg.content,
									).magnetURI;
								} catch (e) {}
								break;
							}
						}
					}

					if (magnetURI && !torrentClient.get(magnetURI)) {
						const blob = new Blob([f.data], {
							type: "application/octet-stream",
						});
						torrentClient.seed(
							blob,
							{ announce: TRACKERS },
							(t: any) => {
								console.log(
									`[BitMeet] Re-seeding: ${t.infoHash}`,
								);
							},
						);
					}
				}
			}
		} catch (e) {
			console.error("[BitMeet] Error in auto-seeding", e);
		}

		p2p.onPeerConnected(async (pubKey: string) => {
			console.log(`Peer conectado: ${pubKey}, sincronizando...`);

			if (pubKey === myIdentity.publicKey) {
				console.log("[Sync] Mi otro dispositivo conectado...");
				
				const pendingFullSync = localStorage.getItem("bitmeet_pending_full_sync") === "true";
				if (pendingFullSync) {
					console.log("[Sync] Iniciando CLONACIÓN COMPLETA de DB...");
					const progressText = document.getElementById("sync-progress-text");
					if (progressText) progressText.textContent = "Obteniendo datos del dispositivo origen...";
					
					p2p.sendP2PMessage(myIdentity.publicKey, {
						type: "full-sync-req",
						senderPubKey: myIdentity.publicKey
					});
					return;
				}

				const lastSync = parseInt(localStorage.getItem("bitmeet_last_sync") || "0");
				p2p.sendP2PMessage(myIdentity.publicKey, {
					type: "device-sync-req",
					lastSyncTs: lastSync,
					senderPubKey: myIdentity.publicKey
				});
				return;
			}

			// 1. Reintentar mensajes que nosotros tenemos como pendientes
			retryPendingMessages(pubKey);

			// 2. Pedir mensajes que el otro pueda tener y nosotros no
			const chatId = await getChatId(myIdentity.publicKey, pubKey);
			syncChat(chatId, pubKey);
		});

		retryPendingMessages(); // Reintentar al conectar inicial

		p2p.onMessageReceived(async (msg: any) => {
			if (msg.type === "device-sync-ping") {
				console.log("[Sync] Otro dispositivo detectado:", msg.fromDeviceId);
				const lastSync = parseInt(localStorage.getItem("bitmeet_last_sync") || "0");
				p2p.sendP2PMessage(myIdentity.publicKey, {
					type: "device-sync-req",
					lastSyncTs: lastSync,
					senderPubKey: myIdentity.publicKey
				});
				return;
			}

			if (msg.type === "device-sync-req") {
				console.log("[Sync] Petición de sincronización recibida de otro dispositivo");
				const chats = await chatRepo.listAllChats();
				const syncMessages: any[] = [];
				const contacts = await chatRepo.listContacts();

				for (const chat of chats) {
					const newMsgs = chat.messages.filter(m => m.timestamp > msg.lastSyncTs);
					// Sincronizamos el chat siempre para asegurar que la estructura (grupos) se replique
					syncMessages.push({
						chatId: chat.id,
						chatName: chat.name,
						chatType: chat.type,
						participants: chat.participants,
						owner: chat.owner,
						lastReadTimestamp: chat.lastReadTimestamp,
						messages: newMsgs
					});
				}

				if (syncMessages.length > 0 || contacts.length > 0) {
					p2p.sendP2PMessage(myIdentity.publicKey, {
						type: "device-sync-res",
						data: syncMessages,
						contacts: contacts,
						senderPubKey: myIdentity.publicKey
					});
				}
				return;
			}

			if (msg.type === "full-sync-req") {
				console.log("[Sync] Petición de clonación de historial recibida.");
				const contacts = await chatRepo.listContacts();
				const chats = await chatRepo.listAllChats();

				// Enviar contactos primero
				p2p.sendP2PMessage(myIdentity.publicKey, {
					type: "full-sync-res-chunk",
					dataType: "contacts",
					data: contacts
				}).catch(e => console.error("Error enviando contactos:", e));

				// Enviar chats uno por uno (para evitar límites de WebRTC)
				for (let i = 0; i < chats.length; i++) {
					await p2p.sendP2PMessage(myIdentity.publicKey, {
						type: "full-sync-res-chunk",
						dataType: "chat",
						data: chats[i],
						progress: Math.round(((i + 1) / chats.length) * 100)
					}).catch(e => console.error(`Error enviando chat ${i}:`, e));
					// Pequeña pausa para no saturar el canal
					await new Promise(res => setTimeout(res, 50));
				}

				p2p.sendP2PMessage(myIdentity.publicKey, {
					type: "full-sync-res-done"
				});
				return;
			}

			if (msg.type === "full-sync-res-chunk") {
				if (msg.dataType === "contacts" && msg.data) {
					for (const c of msg.data) await chatRepo.saveContact(c);
				} else if (msg.dataType === "chat" && msg.data) {
					await chatRepo.saveChat(msg.data);
					const bar = document.getElementById("sync-progress-bar");
					if (bar) bar.style.width = `${msg.progress}%`;
				}
				return;
			}

			if (msg.type === "full-sync-res-done") {
				console.log("[Sync] Clonación finalizada.");
				localStorage.removeItem("bitmeet_pending_full_sync");
				localStorage.setItem("bitmeet_last_sync", Date.now().toString());

				const view = document.getElementById("auth-sync-progress-view");
				const bar = document.getElementById("sync-progress-bar");
				const txt = document.getElementById("sync-progress-text");
				if (bar) bar.style.width = "100%";
				if (txt) txt.textContent = "¡Historial clonado correctamente!";
				
				setTimeout(() => {
					view?.classList.add("hidden");
					authOverlay?.classList.add("hidden");
					teamsApp?.classList.remove("hidden");
					loadContacts();
				}, 1500);
				return;
			}

			if (msg.type === "device-sync-res") {
				console.log("[Sync] Datos de sincronización recibidos");
				if (msg.contacts) {
					for (const c of msg.contacts) {
						await chatRepo.saveContact(c);
					}
				}
				if (msg.data) {
					for (const chatData of msg.data) {
						// Asegurar que el chat existe
						const existingChat = await chatRepo.getChat(chatData.chatId);
						if (!existingChat) {
							await chatRepo.saveChat({
								id: chatData.chatId,
								name: chatData.chatName,
								type: chatData.chatType,
								participants: chatData.participants,
								owner: chatData.owner,
								messages: [],
								lastReadTimestamp: chatData.lastReadTimestamp,
								lastUpdate: Date.now()
							});
						} else {
							// Si ya existe, actualizamos metadata y lastRead si es más reciente
							if (chatData.lastReadTimestamp && (!existingChat.lastReadTimestamp || chatData.lastReadTimestamp > existingChat.lastReadTimestamp)) {
								existingChat.lastReadTimestamp = chatData.lastReadTimestamp;
								await chatRepo.saveChat(existingChat);
							}
						}
						// Guardar mensajes
						for (const m of chatData.messages) {
							await chatRepo.addMessage(chatData.chatId, m);
						}
					}
				}
				localStorage.setItem("bitmeet_last_sync", Date.now().toString());
				loadContacts();
				return;
			}

			if (msg.type === "chat-read") {
				console.log("[Sync] Notificación de lectura recibida para chat:", msg.chatId);
				const chat = await chatRepo.getChat(msg.chatId);
				if (chat) {
					if (!chat.lastReadTimestamp || msg.timestamp > chat.lastReadTimestamp) {
						chat.lastReadTimestamp = msg.timestamp;
						await chatRepo.saveChat(chat);
						loadContacts(); // Refrescar UI
					}
				}
				return;
			}

			if (msg.type === "mark-all-read") {
				console.log("[Sync] Petición de limpieza total recibida");
				await chatRepo.markAllAsRead();
				loadContacts();
				return;
			}

			if (msg.type === "sync-ping") {
				console.log(
					`Recibido sync-ping de ${msg.senderPubKey} para chat ${msg.chatId}. Pide msgs > ${msg.lastReceivedTimestamp}`,
				);
				const chat = await chatRepo.getChat(msg.chatId);
				if (!chat) return;

				const missingMsgs = chat.messages.filter(
					(m) =>
						m.senderPubKey === myIdentity.publicKey &&
						m.timestamp > msg.lastReceivedTimestamp,
				);

				if (missingMsgs.length > 0) {
					console.log(
						`Enviando ${missingMsgs.length} mensajes perdidos a ${msg.senderPubKey}...`,
					);
					for (const m of missingMsgs) {
						const { ciphertext, iv } = await encryptText(
							m.content,
							chat.id,
						);
						await p2p.sendP2PMessage(msg.senderPubKey, {
							type: "chat",
							id: m.id,
							senderPubKey: myIdentity.publicKey,
							senderUsername: myIdentity.username,
							content: ciphertext,
							timestamp: m.timestamp,
							iv,
							groupId: m.groupId,
						});
					}
				}
				return;
			}

			if (msg.type === "calendar-invite") {
				await calendarRepo.saveInvitation({
					id: msg.id,
					eventId: msg.eventId,
					organizerPubKey: msg.organizerPubKey,
					organizerUsername: msg.organizerUsername,
					title: msg.title,
					description: msg.description,
					startTime: msg.startTime,
					endTime: msg.endTime,
					meetingLink: msg.meetingLink,
					isNative: msg.isNative,
					status: "pending",
					receivedAt: Date.now(),
				});

				// También lo guardamos en el chat para que el usuario vea la "tarjeta"
				const chatId = await getChatId(
					msg.organizerPubKey,
					myIdentity.publicKey,
				);
				await chatRepo.addMessage(chatId, {
					id: msg.id,
					senderPubKey: msg.organizerPubKey,
					senderUsername: msg.organizerUsername,
					receiverPubKey: myIdentity.publicKey,
					content: JSON.stringify(msg),
					timestamp: msg.timestamp || Date.now(),
					type: "calendar-invite",
					status: "received",
					iv: "",
				});

				if (notificationsEnabled) {
					sendNotification("Nueva invitación a reunión", `${msg.organizerUsername} te ha invitado a "${msg.title}"`, {
						body: `${msg.organizerUsername} te ha invitado a "${msg.title}"`,
						icon: "/favicon.svg",
					});
				}
				if (!viewCalls?.classList.contains("hidden")) loadCallsView();
				loadContacts(); // Refrescar sidebar para ver el mensaje
				return;
			}

			if (msg.type === "calendar-response") {
				const event = await calendarRepo.getEvent(msg.eventId);
				if (event) {
					// En una implementación real, podríamos guardar quién aceptó.
					// Por ahora, notificamos al organizador.
					if (notificationsEnabled) {
						sendNotification("Respuesta a reunión", `${msg.responderUsername} ha ${msg.status === "accepted" ? "aceptado" : "rechazado"} la reunión "${event.title}"`, {
							body: `${msg.responderUsername} ha ${msg.status === "accepted" ? "aceptado" : "rechazado"} la reunión "${event.title}"`,
							icon: "/favicon.svg",
						});
					}
				}
				return;
			}

			if (msg.type === "calendar-cancel") {
				await calendarRepo.deleteEvent(msg.eventId);
				// Si la vista de calendario está activa, refrescarla
				if (!viewCalendar?.classList.contains("hidden")) {
					renderCalendar();
				}
				return;
			}

			if (msg.type === "chat" || msg.type === "system") {
				const isGroup = !!msg.groupId;
				
				// Determinar el interlocutor real para el chatId
				let otherPubKey = msg.senderPubKey;
				if (!isGroup && msg.senderPubKey === myIdentity.publicKey && msg.receiverPubKey) {
					// El mensaje fue enviado por nuestro otro dispositivo
					otherPubKey = msg.receiverPubKey;
				}

				const chatId = isGroup
					? msg.groupId
					: await getChatId(otherPubKey, myIdentity.publicKey);

				// Verificar bloqueo usando la clave del otro usuario
				const contact = await chatRepo.getContact(otherPubKey);
				if (contact?.isBlocked) return;

				let text = msg.content;
				let decryptedData = null;

				try {
					text = await decryptText(msg.content, msg.iv, chatId);
					if (msg.type === "system") {
						decryptedData = JSON.parse(text);
					}
				} catch (e) {
					text = "🔒 Error de cifrado";
				}

				const message = {
					id: msg.id,
					senderPubKey: msg.senderPubKey,
					senderUsername: msg.senderUsername,
					receiverPubKey: msg.receiverPubKey || (isGroup ? undefined : myIdentity.publicKey),
					groupId: isGroup ? msg.groupId : undefined,
					content: text,
					timestamp: msg.timestamp,
					type:
						msg.msgType ||
						(msg.type === "system" ? "system" : "text"),
					systemAction: msg.systemAction,
					status: "received",
					iv: msg.iv,
				};

				// Si me han expulsado o me he ido, y recibo un mensaje de ese grupo, lo ignoro si ya no estoy
				if (
					isGroup &&
					(msg.systemAction === "member_removed" ||
						msg.systemAction === "member_left")
				) {
					if (
						decryptedData &&
						!decryptedData.participants.includes(
							myIdentity.publicKey,
						)
					) {
						// He sido expulsado o ya me fui (mensaje duplicado o tardío). Podríamos borrar el chat.
						const db = (chatRepo as any).db;
						if (db) {
							const tx = db.transaction("chats", "readwrite");
							tx.objectStore("chats").delete(chatId);
						}
						if (currentChatId === chatId) {
							viewActiveChat?.classList.add("hidden");
							viewNoChat?.classList.remove("hidden");
						}
						loadContacts();
						return;
					}
				}

				await chatRepo.addMessage(chatId, message as any);

				// Notificar al overlay si está abierto
				window.dispatchEvent(
					new CustomEvent("bitmeet:new-message", {
						detail: { chatId, message },
					}),
				);

				if (currentChatId === chatId) {
					if (msg.type === "system") {
						// Actualizar UI en tiempo real si el chat está abierto
						if (
							msg.systemAction === "group_renamed" &&
							decryptedData?.newName
						) {
							document.getElementById(
								"active-chat-name",
							)!.textContent = decryptedData.newName;
						} else if (decryptedData?.participants) {
							currentGroupParticipants =
								decryptedData.participants;
							const statusEl =
								document.getElementById("active-chat-status")!;
							statusEl.textContent = `${currentGroupParticipants.length} participantes`;
							// Si el modal está abierto, refrescar lista de miembros
							if (
								!groupSettingsModal?.classList.contains(
									"hidden",
								)
							) {
								const isOwner =
									currentGroupOwner === myIdentity.publicKey;
								renderGroupParticipants(
									currentGroupParticipants,
									isOwner,
								);
							}
						}
					}

					const lastMsgEl = document.querySelector(
						"#messages-list .message-bubble:last-child",
					) as HTMLElement;
					const lastTs = lastMsgEl
						? parseInt(
								lastMsgEl.getAttribute("data-timestamp") || "0",
							)
						: 0;

					if (message.timestamp < lastTs) {
						await loadChatHistory(chatId);
					} else {
						renderMessage(message as any);
						scrollToBottom();
					}

					if (!isGroup) {
						// Actualizar nombre si era desconocido, a no ser que seamos nosotros mismos
						const nameEl =
							document.getElementById("active-chat-name");
						if (
							nameEl &&
							nameEl.textContent?.includes("Desconocido") &&
							msg.senderUsername &&
							msg.senderPubKey !== myIdentity.publicKey
						) {
							nameEl.textContent = msg.senderUsername;
							await chatRepo.saveContact({
								publicKey: msg.senderPubKey,
								username: msg.senderUsername,
								isFavorite: false,
							});
							const sidebarItem =
								document.querySelector(
									`[data-pubkey="${msg.senderPubKey}"] strong`,
								) ||
								document.querySelector(
									`[data-id="${msg.senderPubKey}"] strong`,
								);
							if (sidebarItem)
								sidebarItem.textContent = msg.senderUsername;
						}
					}
					await chatRepo.markAsRead(chatId);
					p2p.sendP2PMessage(myIdentity.publicKey, {
						type: "chat-read",
						chatId: chatId,
						timestamp: Date.now(),
						senderPubKey: myIdentity.publicKey
					}).catch(e => console.warn("[Sync] Error notificando lectura automática:", e));
					await loadContacts(); // REFRESCAR SIDEBAR INMEDIATAMENTE
				}

				await loadContacts();

				// Notificaciones
				if (notificationsEnabled && msg.type !== "system") {
					playNotificationSound();
					
					if (document.hidden) {
						const title = isGroup
							? `Mensaje en grupo`
							: `Mensaje de @${msg.senderUsername}`;
						
						sendNotification(title, text, {
							body: text,
							icon: "/favicon.svg",
						});
					}
				}
			} else if (msg.type === "call-invite") {
				document.getElementById("incoming-caller-name")!.textContent =
					msg.callerName || "Llamada entrante";
				incomingPopup?.classList.remove("hidden");
				ringtone?.play();
				pendingCallPubKey = msg.senderPubKey;

				// GUARDAR INVITED PEERS PARA EL OVERLAY
				(window as any).pendingInvitedPeers = msg.invitedPeers;

				// Importante: Guardamos el PeerID del emisor que viene en el mensaje P2P
				if (msg.peerId) {
					console.log(
						"[BitMeet] Call invite received with PeerID:",
						msg.peerId,
					);
					(window as any).pendingCallerPeerId = msg.peerId;
				}

				if (notificationsEnabled) {
					sendNotification("BitMeet", `Llamada entrante de @${msg.callerName}`, {
						body: `Llamada entrante de @${msg.callerName}`,
						icon: "/favicon.svg",
					});
				}
			} else if (msg.type === "call-handled") {
				console.log("[BitMeet] Call handled on another device. Stopping ringtone.");
				incomingPopup?.classList.add("hidden");
				ringtone?.pause();
				ringtone!.currentTime = 0;
				pendingCall = null;
				pendingCallPubKey = null;
				userAcceptedPending = false;
			} else if (msg.type === "call-accept") {
				console.log(
					"[BitMeet] El receptor ha aceptado la llamada con PeerID:",
					msg.peerId,
				);
				window.dispatchEvent(
					new CustomEvent("bitmeet:call-accepted", { detail: msg }),
				);
			} else if (msg.type === "call-reject") {
				import("../lib/callStore").then((store) => {
					store.endCall();
				});
				alert(`@${msg.senderUsername} ha rechazado la llamada.`);
			}
		});

		p2p.onIncomingCall(async (call: any) => {
			console.log("[BitMeet] PeerJS Call incoming from:", call.peer);
			pendingCall = call;

			// Si ya habíamos aceptado por el mensaje de chat P2P, contestamos YA
			if (userAcceptedPending && pendingCallPubKey) {
				console.log(
					"[BitMeet] Auto-answering call because user already clicked accept",
				);
				incomingPopup?.classList.add("hidden");
				ringtone?.pause();
				ringtone!.currentTime = 0;
				const roomId = await getChatId(
					myIdentity.publicKey,
					pendingCallPubKey,
				);
				const name =
					document.getElementById("incoming-caller-name")!
						.textContent || "Usuario";
				const invitedPeers = (window as any).pendingInvitedPeers || {};
				receiveCall(
					roomId,
					pendingCall,
					null,
					undefined,
					pendingCallPubKey,
					name,
					invitedPeers,
				);
				pendingCall = null;
				pendingCallPubKey = null;
				userAcceptedPending = false;
			}
		});
	}

	// 4. ACCIONES DE LLAMADA
	document
		.getElementById("btn-accept-call")
		?.addEventListener("click", async () => {
			console.log(
				"[BitMeet] Accept button clicked. pendingCall:",
				!!pendingCall,
				"pendingCallPubKey:",
				!!pendingCallPubKey,
			);

			if (pendingCallPubKey) {
				const roomId = await getChatId(
					myIdentity.publicKey,
					pendingCallPubKey,
				);

				// ENVIAMOS ACEPTACIÓN INMEDIATA POR P2P CHAT AL QUE LLAMA
				const acceptPayload = {
					type: "call-accept",
					peerId: myIdentity.publicKey,
					senderPubKey: myIdentity.publicKey,
					senderUsername: myIdentity.username,
				};

				p2p.sendP2PMessage(pendingCallPubKey, acceptPayload);

				// Sincronizar otros dispositivos míos (Silencioso, sin esperar)
				p2p.sendP2PMessage(myIdentity.publicKey, { type: "call-handled" }).catch(() => {});

				// FULL MESH: También enviamos aceptación a los demás invitados para que nos vean
				const invitedPeersMap = (window as any).pendingInvitedPeers;
				if (invitedPeersMap) {
					Object.values(invitedPeersMap).forEach((peerInfo: any) => {
						if (
							peerInfo.pubKey &&
							peerInfo.pubKey !== myIdentity.publicKey &&
							peerInfo.pubKey !== pendingCallPubKey
						) {
							console.log(
								"[BitMeet] Notificando a compañero de grupo que me uno:",
								peerInfo.username,
							);
							p2p.sendP2PMessage(
								peerInfo.pubKey,
								acceptPayload,
							).catch(() => {});
						}
					});
				}

				incomingPopup?.classList.add("hidden");
				ringtone?.pause();
				ringtone!.currentTime = 0;

				const name =
					document.getElementById("incoming-caller-name")!
						.textContent || "Usuario";
				const invitedPeers = (window as any).pendingInvitedPeers || {};
				const callerPeerId = (window as any).pendingCallerPeerId;

				// FULL MESH: El receptor debe incluir al Host en su lista de 'invitedPeers'
				// para que la lógica de conexión automática en CallOverlay funcione para todos.
				const fullInvitedPeers = { ...invitedPeers };
				if (callerPeerId && pendingCallPubKey) {
					fullInvitedPeers[callerPeerId] = {
						username: name,
						pubKey: pendingCallPubKey,
					};
				}

				if (pendingCall) {
					console.log("[BitMeet] Answering existing PeerJS call...");
					receiveCall(
						roomId,
						pendingCall,
						null,
						undefined,
						pendingCallPubKey,
						name,
						fullInvitedPeers,
					);
				} else {
					console.log(
						"[BitMeet] Waiting for PeerJS call to arrive in overlay...",
					);
					// Entramos en el overlay aunque el objeto 'call' no haya llegado aún
					// IMPORTANTE: Usamos receiveCall para que el estado sea 'isIncoming: true'
					receiveCall(
						roomId,
						null,
						null,
						undefined,
						pendingCallPubKey,
						name,
						fullInvitedPeers,
					);
				}

				pendingCall = null;
				pendingCallPubKey = null;
				userAcceptedPending = false;
			}
		});

