{
  "rules": {
    "signaling": {
      "p2p": {
        ".read": true,
        ".write": true
      },
      "calls": {
        ".read": true,
        ".write": true
      },
      ".read": true,
      ".write": true
    },
    "users": {
      ".read": true,
      ".write": true
    },
    "presence": {
      ".read": true,
      ".write": true
    },
    "rooms": {
      "$roomId": {
        ".read": true,
        ".write": true
      }
    },
    "pairing": {
      "$code": {
        ".read": true,
        ".write": "!data.exists() || !newData.exists()",
        ".validate": "newData.hasChildren(['data', 'createdAt'])"
      }
    }
  }
}
